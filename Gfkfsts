						break;
					end
				end
			end
		end
		if closest then
			hrp.CFrame = CFrame.new(closest.Position + Vector3.new(0, 3, 0));
		end
	end
	CreateExploitButton(ExploitsTab, "ТП к раненому/упавшему союзнику", TeleportToClosestDowned);
	CreateExploitButton(ExploitsTab, "ТП к воротам/выходу (Ближайший)", TeleportToExit);
	CreatePureColorPicker(SettingsTab, "Цвет меню (Тема)", "ThemeColor", function()
		UpdateThemeUI();
	end);
	CreateSlider(SettingsTab, "Время суток (Часы)", 0, 24, 14, function(val)
		local FlatIdent_1DE58 = 0;
		while true do
			if (FlatIdent_1DE58 == 0) then
				Config.TimeValue = val;
				if not Config.Fullbright then
					Lighting.ClockTime = val;
				end
				break;
			end
		end
	end);
	UpdateThemeUI();
end);
if not success then
	warn("[Luna V4 Mobile Load Error]: " .. tostring(launchError));
end
