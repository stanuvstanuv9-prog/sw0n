        frame.Visible = (name == tabName)
    end
    for name, btn in pairs(tabButtons) do
        btn.TextColor3 = (name == tabName) and Color3.fromRGB(0, 180, 255) or Color3.fromRGB(150, 150, 150)
    end
end

