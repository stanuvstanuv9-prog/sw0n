                            label.Parent = textESP
                            textESP.Parent = folder
                        end
                        textESP.Adornee = character.HumanoidRootPart
                        textESP.Label.Text = currentText .. "\n" .. player.DisplayName
                        textESP.Label.TextColor3 = currentColor
                    else
                        if textESP then textESP:Destroy() end
                    end
                    
                    -- БОКС ESP (HIGHLIGHT)
                    local boxESP = folder:FindFirstChild("Luna_Highlight")
                    if Config.Box then
                        if not boxESP then
                            boxESP = Instance.new("Highlight")
                            boxESP.Name = "Luna_Highlight"
                            boxESP.FillTransparency = 1
                            boxESP.OutlineTransparency = 0
                            boxESP.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                            boxESP.Parent = folder
                        end
                        boxESP.Adornee = character
                        boxESP.OutlineColor = currentColor
                    else
                        if boxESP then boxESP:Destroy() end
                    end
                    
                end
            end
        end
    end
end)

-- [[ ОТРИСОВКА ЛИНИЙ (TRACERS) НА СВЕРХПЛАВНОМ ДВИЖКЕ ]] --
table.insert(connections, RunService.RenderStepped:Connect(function()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local character = player.Character
            local root = character and character:FindFirstChild("HumanoidRootPart")
            
            if Config.Tracers and root and pcall(function() return Drawing end) then
                local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
                if onScreen then
                    local tracer = tracerCache[player]
                    if not tracer then
                        tracer = Drawing.new("Line")
                        tracer.Thickness = 1
                        tracer.Transparency = 1
                        tracerCache[player] = tracer
                    end
                    
                    local isKiller = checkIsKiller(player, character)
                    tracer.Color = isKiller and Color3.fromRGB(255, 30, 30) or Color3.fromRGB(0, 255, 120)
                    tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                    tracer.Visible = true
                else
                    if tracerCache[player] then tracerCache[player].Visible = false end
                end
            else
                if tracerCache[player] then tracerCache[player].Visible = false end
            end
        end
    end
    
    -- Чистка кэша линий при выходе игрока
    for player, tracer in pairs(tracerCache) do
        if not Players:FindFirstChild(player.Name) then
            tracer:Remove()
            tracerCache[player] = nil
        end
    end
end))

