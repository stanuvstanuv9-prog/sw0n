    local function colorToTable(color) return {color.R, color.G, color.B} end
    local function tableToColor(tbl) return Color3.new(tbl[1], tbl[2], tbl[3]) end

    local function saveSettings(name)
        if not writefile then return end
        local data = {}
        for k, v in pairs(Config) do
            if typeof(v) == "Color3" then
                data[k] = {__isColor = true, data = colorToTable(v)}
            else
                data[k] = v
            end
        end
        local ok, str = pcall(function() return HttpService:JSONEncode(data) end)
        if ok then pcall(function() writefile(folderPath .. "/" .. name .. ".cfg", str) end) end
    end

    local function loadSettings(name)
        if not readfile then return end
        local file = folderPath .. "/" .. name .. ".cfg"
        if not isfile(file) then return end
        
        local content = readfile(file)
        local ok, decoded = pcall(function() return HttpService:JSONDecode(content) end)
        if ok and type(decoded) == "table" then
            for k, v in pairs(decoded) do
                if type(v) == "table" and v.__isColor then
                    Config[k] = tableToColor(v.data)
                else
                    Config[k] = v
                end
            end
            -- Обновляем кнопки на самом экране GUI
            for prop, updateFunc in pairs(uiRegistry) do
                updateFunc(Config[prop])
            end
        end
    end

