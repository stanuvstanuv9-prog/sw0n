-- [[ REALIZATION: DRAWING ESP (BOX, CORNER, TRACERS) ]] --
local function CreateDrawingESP(player)
    if player == LocalPlayer then return end

    local box = Drawing.new("Square")
    box.Visible = false
    box.Color = Color3.fromRGB(255, 255, 255)
    box.Thickness = 1
    box.Filled = false

    local tracer = Drawing.new("Line")
    tracer.Visible = false
    tracer.Color = Color3.fromRGB(255, 255, 255)
    tracer.Thickness = 1

    -- Углы для Corner ESP (4 линии)
    local corners = {
        TopLeftH = Drawing.new("Line"), TopLeftV = Drawing.new("Line"),
        TopRightH = Drawing.new("Line"), TopRightV = Drawing.new("Line"),
        BotLeftH = Drawing.new("Line"), BotLeftV = Drawing.new("Line"),
        BotRightH = Drawing.new("Line"), BotRightV = Drawing.new("Line")
    }

    for _, c in pairs(corners) do
        c.Visible = false
        c.Color = Color3.fromRGB(255, 255, 255)
        c.Thickness = 1
    end

    drawingVisuals[player] = {Box = box, Tracer = tracer, Corners = corners}

    local function update()
        local connection
        connection = RunService.RenderStepped:Connect(function()
            if not drawingVisuals[player] then connection:Disconnect() return end
            
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")

            if char and root and hum and hum.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
                
                if onScreen then
                    -- Определяем цвет (Маньяк / Выживший)
                    local color = Color3.fromRGB(0, 255, 120)
                    if player.Team and (player.Team.Name:lower():find("kill") or player.Team.Name:lower():find("slash") or player.Team.Name:lower():find("beast")) or char:FindFirstChildOfClass("Tool") or char:GetAttribute("Role") == "Killer" then
                        color = Color3.fromRGB(255, 30, 30)
                    end

                    -- Расчет размеров бокса на основании дистанции
                    local sizeX = 1000 / pos.Z
                    local sizeY = 1300 / pos.Z
                    local posX = pos.X - sizeX / 2
                    local posY = pos.Y - sizeY / 2

                    -- Точка старта трейсеров (снизу экрана по центру)
                    local screenCenterBottom = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)

                    -- 1. Обработка Обычного Box ESP
                    if Config.BoxESP then
                        box.Size = Vector2.new(sizeX, sizeY)
                        box.Position = Vector2.new(posX, posY)
                        box.Color = color
                        box.Visible = true
                    else
                        box.Visible = false
                    end

                    -- 2. Обработка Corner ESP (Угловой)
                    if Config.CornerESP then
                        local length = sizeX / 4
                        corners.TopLeftH.From = Vector2.new(posX, posY)
                        corners.TopLeftH.To = Vector2.new(posX + length, posY)
                        corners.TopLeftV.From = Vector2.new(posX, posY)
                        corners.TopLeftV.To = Vector2.new(posX, posY + length)

                        corners.TopRightH.From = Vector2.new(posX + sizeX, posY)
                        corners.TopRightH.To = Vector2.new(posX + sizeX - length, posY)
                        corners.TopRightV.From = Vector2.new(posX + sizeX, posY)
                        corners.TopRightV.To = Vector2.new(posX + sizeX, posY + length)

                        corners.BotLeftH.From = Vector2.new(posX, posY + sizeY)
                        corners.BotLeftH.To = Vector2.new(posX + length, posY + sizeY)
                        corners.BotLeftV.From = Vector2.new(posX, posY + sizeY)
                        corners.BotLeftV.To = Vector2.new(posX, posY + sizeY - length)

                        corners.BotRightH.From = Vector2.new(posX + sizeX, posY + sizeY)
                        corners.BotRightH.To = Vector2.new(posX + sizeX - length, posY + sizeY)
                        corners.BotRightV.From = Vector2.new(posX + sizeX, posY + sizeY)
                        corners.BotRightV.To = Vector2.new(posX + sizeX, posY + sizeY - length)

                        for _, c in pairs(corners) do c.Color = color; c.Visible = true end
                    else
                        for _, c in pairs(corners) do c.Visible = false end
                    end

                    -- 3. Обработка Трейсеров (Линий)
                    if Config.Tracers then
                        tracer.From = screenCenterBottom
                        tracer.To = Vector2.new(pos.X, pos.Y + (sizeY / 2))
                        tracer.Color = color
                        tracer.Visible = true
                    else
                        tracer.Visible = false
                    end
                else
                    box.Visible = false
                    tracer.Visible = false
                    for _, c in pairs(corners) do c.Visible = false end
                end
            else
                box.Visible = false
                tracer.Visible = false
                for _, c in pairs(corners) do c.Visible = false end
            end
        end)
    end
    coroutine.wrap(update)()
end

