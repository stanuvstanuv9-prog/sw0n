-- 1. Улучшенный ESP (Проверка ролей)
local function applyESP(player)
    if player == LocalPlayer then return end
    
    local function characterAdded(character)
        if not Config.ESP then return end
        task.wait(0.5)
        if espObjects[player] then espObjects[player]:Destroy() end
        
        local highlight = Instance.new("Highlight")
        highlight.Parent = character
        highlight.Adornee = character
        highlight.FillOpacity = 0.25
        highlight.OutlineOpacity = 1
        
        -- Умная проверка на Убийцу
        local isKiller = false
        if player.Team and (player.Team.Name:lower():find("killer") or player.Team.Name:lower():find("slasher") or player.Team.Name:lower():find("murder") or player.Team.Name:lower():find("beast")) then
            isKiller = true
        elseif character:UrgentWaitForChild("Weapon", 2) or character:FindFirstChild("Knife") or character:SetAttribute("Role") == "Killer" then
            -- Дополнительная проверка на наличие оружия в руках персонажа
            isKiller = true
        end
        
        if isKiller then
            highlight.FillColor = Color3.fromRGB(255, 0, 50) -- Настоящий убийца КРАСНЫЙ
            highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
        else
            highlight.FillColor = Color3.fromRGB(0, 180, 255) -- Выжившие СИНИЙ/ГОЛУБОЙ
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        end
        espObjects[player] = highlight
    end
    
    player.CharacterAdded:Connect(characterAdded)
    if player.Character then characterAdded(player.Character) end
end

local function toggleESP(state)
    if state then
        for _, p in ipairs(Players:GetPlayers()) do applyESP(p) end
        table.insert(connections, Players.PlayerAdded:Connect(applyESP))
    else
        for p, h in pairs(espObjects) do if h then h:Destroy() end end
        table.clear(espObjects)
    end
end

-- 2. ESP на Генераторы и Палеты (Объекты)
local function toggleObjectESP(state)
    if state then
        table.insert(connections, RunService.Heartbeat:Connect(function()
            if not Config.ObjectESP then return end
            -- Сканируем карту на наличие важных объектов
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("Model") and (obj.Name:lower():find("generator") or obj.Name:lower():find("pallet") or obj.Name:lower():find("engine")) then
                    if not obj:FindFirstChild("Luna_ObjESP") then
                        local box = Instance.new("BoxHandleAdornment")
                        box.Name = "Luna_ObjESP"
                        box.Size = obj:GetExtentsSize() + Vector3.new(0.1, 0.1, 0.1)
                        box.Color3 = obj.Name:lower():find("generator") and Color3.fromRGB(240, 200, 0) or Color3.fromRGB(150, 75, 0) -- Желтый для генераторов, коричневый для палет
                        box.AlwaysOnTop = true
                        box.ZIndex = 5
                        box.Adornee = obj
                        box.Transparency = 0.6
                        box.Parent = obj
                        table.insert(objectEspList, box)
                    end
                end
            end
        end))
    else
        for _, v in ipairs(objectEspList) do pcall(function() v:Destroy() end) end
        table.clear(objectEspList)
    end
end

-- 3. Продвинутый Авто-Скиллчек
local function toggleSkillCheck(state)
    if not state then return end
    local playerGui = LocalPlayer:WaitForChild("PlayerGui", 5)
    
    local function checkUI(descendant)
        if Config.AutoSkillCheck then
            -- Проверяем UI элементы на маркеры зон успеха скиллчека
            if descendant:IsA("Frame") or descendant:IsA("ImageLabel") then
                if descendant.Name:lower():find("success") or descendant.Name:lower():find("perfect") or descendant.Name:lower():find("zone") then
                    task.wait(0.02) -- Моментальный прок
                    local vim = game:GetService("VirtualInputManager")
                    vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                    task.wait(0.01)
                    vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
                end
            end
        end
    end
    
    table.insert(connections, playerGui.DescendantAdded:Connect(checkUI))
end

-- 4. Спидхак и NoFall
table.insert(connections, RunService.RenderStepped:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local hum = LocalPlayer.Character.Humanoid
        -- Спидхак
        if Config.Speedhack then
            hum.WalkSpeed = Config.SpeedValue
        end
        -- NoFall (Отключаем падение и урон штатным способом)
        if Config.NoFall then
            if hum:GetState() == Enum.HumanoidStateType.Freefall then
                hum:ChangeState(Enum.HumanoidStateType.Running)
            end
        end
    end
end))

-- 5. Noclip
table.insert(connections, RunService.Stepped:Connect(function()
    if Config.Noclip and LocalPlayer.Character then
        for _, part in ipairs(LocalPlayer.Character:GetChildren()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end
end))

