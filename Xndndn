    Label.BackgroundTransparency = 1
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(235, 235, 235)
    Label.Font = Enum.Font.GothamBold -- Усиленный жирный текст настроек
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
