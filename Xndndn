            PCorn.CornerRadius = UDim.new(0, 4)
            PCorn.Parent = Palette

            local PGrid = Instance.new("UIGridLayout")
            PGrid.CellSize = UDim2.new(0, 20, 0, 20)
            PGrid.CellPadding = UDim2.new(0, 4, 0, 4)
            PGrid.SortOrder = Enum.SortOrder.LayoutOrder
            PGrid.Parent = Palette

            local PPad = Instance.new("UIPadding")
            PPad.PaddingLeft = UDim.new(0, 4)
            PPad.PaddingTop = UDim.new(0, 4)
            PPad.Parent = Palette

            local colors = {
