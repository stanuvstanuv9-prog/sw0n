        SVMap.Position = UDim2.new(0, 0, 0, 5)
        SVMap.Text = ""
        SVMap.AutoButtonColor = false
        SVMap.Parent = Palette
        Instance.new("UICorner", SVMap).CornerRadius = UDim.new(0, 4)

        local WhiteOv = Instance.new("Frame", SVMap)
        WhiteOv.Size = UDim2.new(1,0,1,0)
        WhiteOv.BackgroundColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", WhiteOv).CornerRadius = UDim.new(0, 4)
        local wg = Instance.new("UIGradient", WhiteOv)
        wg.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1)})

        local BlackOv = Instance.new("Frame", SVMap)
        BlackOv.Size = UDim2.new(1,0,1,0)
        BlackOv.BackgroundColor3 = Color3.new(0,0,0)
        Instance.new("UICorner", BlackOv).CornerRadius = UDim.new(0, 4)
        local bg = Instance.new("UIGradient", BlackOv)
        bg.Rotation = 90
        bg.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(1,0)})

        local SVMarker = Instance.new("Frame", BlackOv)
        SVMarker.Size = UDim2.new(0,8,0,8)
        SVMarker.AnchorPoint = Vector2.new(0.5, 0.5)
        SVMarker.BackgroundColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", SVMarker).CornerRadius = UDim.new(1,0)
        Instance.new("UIStroke", SVMarker).Color = Color3.new(0,0,0)

        local HueMap = Instance.new("TextButton")
        HueMap.Size = UDim2.new(0, 20, 1, -10)
        HueMap.Position = UDim2.new(1, -20, 0, 5)
        HueMap.Text = ""
        HueMap.AutoButtonColor = false
        HueMap.BackgroundColor3 = Color3.new(1,1,1)
        HueMap.Parent = Palette
        Instance.new("UICorner", HueMap).CornerRadius = UDim.new(0, 4)

        local hg = Instance.new("UIGradient", HueMap)
        hg.Rotation = 90
        hg.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255,0,0)),
            ColorSequenceKeypoint.new(0.167, Color3.fromRGB(255,255,0)),
            ColorSequenceKeypoint.new(0.333, Color3.fromRGB(0,255,0)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0,255,255)),
            ColorSequenceKeypoint.new(0.667, Color3.fromRGB(0,0,255)),
            ColorSequenceKeypoint.new(0.833, Color3.fromRGB(255,0,255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255,0,0))
        })

        local HueMarker = Instance.new("Frame", HueMap)
        HueMarker.Size = UDim2.new(1, 4, 0, 4)
        HueMarker.AnchorPoint = Vector2.new(0.5, 0.5)
        HueMarker.BackgroundColor3 = Color3.new(1,1,1)
        Instance.new("UIStroke", HueMarker).Color = Color3.new(0,0,0)

        local h, s, v = Config[colorPropName]:ToHSV()
        SVMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)

        local function UpdateColorParams()
            local newColor = Color3.fromHSV(h, s, v)
            Config[colorPropName] = newColor
            colorBtn.BackgroundColor3 = newColor
            SVMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)

            HueMarker.Position = UDim2.new(0.5, 0, 1 - h, 0)
            SVMarker.Position = UDim2.new(s, 0, 1 - v, 0)

            if colorCallback then colorCallback(newColor) end
        end
        UpdateColorParams()

        local draggingSV, draggingHue = false, false
        local function handleInput(input, isHue)
            if isHue then
                local y = math.clamp(input.Position.Y - HueMap.AbsolutePosition.Y, 0, HueMap.AbsoluteSize.Y)
                h = 1 - (y / HueMap.AbsoluteSize.Y)
            else
                local x = math.clamp(input.Position.X - SVMap.AbsolutePosition.X, 0, SVMap.AbsoluteSize.X)
                local y = math.clamp(input.Position.Y - SVMap.AbsolutePosition.Y, 0, SVMap.AbsoluteSize.Y)
                s = x / SVMap.AbsoluteSize.X
                v = 1 - (y / SVMap.AbsoluteSize.Y)
            end
            UpdateColorParams()
        end

        SVMap.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingSV = true; handleInput(inp, false)
            end
        end)
        HueMap.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingHue = true; handleInput(inp, true)
            end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingSV = false; draggingHue = false
            end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseMovement then
                if draggingSV then handleInput(inp, false) end
                if draggingHue then handleInput(inp, true) end
            end
        end)
    end

