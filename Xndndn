-- Включение/Выключение старого Billboard ESP
local function applyPlayerESP(player)
    if player == LocalPlayer then return end
    local function onChar(character)
        if espFolders[player] then pcall(function() espFolders[player]:Destroy() end) end
        if not Config.ESP then return end
        local root = character:WaitForChild("HumanoidRootPart", 5)
        if not root then return end
        
        local folder = Instance.new("Folder", character)
        folder.Name = "Luna_ESP"
        espFolders[player] = folder

        local bb = Instance.new("BillboardGui", folder)
        bb.Size = UDim2.new(0, 160, 0, 40)
        bb.AlwaysOnTop = true
        bb.Adornee = root

        local txt = Instance.new("TextLabel", bb)
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Font = Enum.Font.GothamBold
        txt.TextSize = 12
        txt.TextStrokeTransparency = 0
        
        local isKiller = player.Team and (player.Team.Name:lower():find("kill") or player.Team.Name:lower():find("slash")) or character:GetAttribute("Role") == "Killer"
        txt.Text = isKiller and ("[ МАНЬЯК ]\n" .. player.DisplayName) or ("[ Выживший ]\n" .. player.DisplayName)
        txt.TextColor3 = isKiller and Color3.fromRGB(255, 30, 30) or Color3.fromRGB(0, 255, 120)
    end
    player.CharacterAdded:Connect(onChar)
    if player.Character then onChar(player.Character) end
end

local function toggleNameESP(state)
    if state then
        for _, p in ipairs(Players:GetPlayers()) do applyPlayerESP(p) end
    else
        for _, f in pairs(espFolders) do pcall(function() f:Destroy() end) end
        table.clear(espFolders)
    end
end

