local function togglePerfectSkillCheck(state)
    if not state then return end
    local pGui = LocalPlayer:WaitForChild("PlayerGui")
    local function scanUI(descendant)
        if Config.PerfectSkillCheck and descendant:IsA("GuiObject") then
            local name = descendant.Name:lower()
            if name:find("perfect") or name:find("great") or name:find("white") or name:find("bonus") then
                task.wait(0.005) 
                local vim = game:GetService("VirtualInputManager")
                vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                task.wait(0.01)
                vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
            end
        end
    end
    table.insert(connections, pGui.DescendantAdded:Connect(scanUI))
end

table.insert(connections, RunService.Heartbeat:Connect(function()
    if Config.RemoteRepair and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        if not lockedGenerator then
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj.Name:lower():find("generator") or obj:GetAttribute("Type") == "Generator" then
                    local mainPart = obj:FindFirstChild("MainPart") or obj:FindFirstChildOfClass("BasePart")
                    if mainPart and (LocalPlayer.Character.HumanoidRootPart.Position - mainPart.Position).Magnitude < 12 then
                        lockedGenerator = obj
                        break
                    end
                end
            end
        end
        if lockedGenerator then
            if lockedGenerator:FindFirstChild("RemoteEvent") then
                lockedGenerator.RemoteEvent:FireServer("Repair", true)
            elseif lockedGenerator:GetAttribute("Progress") then
                local currentProg = lockedGenerator:GetAttribute("Progress")
                if currentProg and currentProg < 100 then
                    lockedGenerator:SetAttribute("Progress", currentProg + 0.1)
                end
            end
        end
    else lockedGenerator = nil end
end))

CreateToggle(ExploitsTab, "Perfect Auto-Skillcheck", "PerfectSkillCheck", togglePerfectSkillCheck)
