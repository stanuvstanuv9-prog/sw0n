                        folder.Parent = character
                    end
                    
                    local isKiller = checkIsKiller(player, character)
                    local currentColor = isKiller and Color3.fromRGB(255, 30, 30) or Color3.fromRGB(0, 255, 120)
                    local currentText = isKiller and "[ LUNA BYPASS ]" or "[ LUNA BYPASS]"
                    
                    -- ТЕКСТ ESP
                    local textESP = folder:FindFirstChild("Luna_Text")
                    if Config.ESP then
                        if not textESP then
                            textESP = Instance.new("BillboardGui")
                            textESP.Name = "Luna_Text"
                            textESP.Size = UDim2.new(0, 160, 0, 40)
                            textESP.AlwaysOnTop = true
                            local label = Instance.new("TextLabel")
