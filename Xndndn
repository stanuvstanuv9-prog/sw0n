    UserInputService.InputBegan:Connect(function(i, g)
        if not g and (i.KeyCode == Enum.KeyCode.Insert or i.KeyCode == Enum.KeyCode.RightShift) then
            MainFrame.Visible = not MainFrame.Visible
            ToggleBlur(MainFrame.Visible)
        end
    end)

