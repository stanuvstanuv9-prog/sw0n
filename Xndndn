table.insert(connections, RunService.RenderStepped:Connect(function(dt)
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.MoveDirection.Magnitude > 0 then
            if Config.CFrameSpeed then
                local currentSpeed = Config.SpeedValue
                if Config.AutoSprint and isSprinting then
                    currentSpeed = Config.SpeedValue * 1.8
                end
                hrp.CFrame = hrp.CFrame + (hum.MoveDirection * (currentSpeed * dt * 10))
            end
        end
    end
end))

table.insert(connections, RunService.RenderStepped:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if Config.NoFall and hum:GetState() == Enum.HumanoidStateType.Freefall then
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
        if not Config.CFrameSpeed and Config.AutoSprint then
            if isSprinting and hum.WalkSpeed ~= Config.SprintWalkSpeed then
                hum.WalkSpeed = Config.SprintWalkSpeed
            elseif not isSprinting and hum.WalkSpeed == Config.SprintWalkSpeed then
                hum.WalkSpeed = Config.NormalWalkSpeed
            end
        end
    end
end))

