    local VisualsTab  = CreateTab("Visuals")
    local ExploitsTab = CreateTab("Exploits")
    local SettingsTab = CreateTab("Settings")

    CreateToggle(MainTab, "Speedhack (CFrame)", "CFrameSpeed")
