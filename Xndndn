    local function CreateSlider(parent, labelText, min, max, default, callback)
        local Frame = Instance.new("Frame")
        Frame.Size = UDim2.new(1, -5, 0, 45)
        Frame.BackgroundColor3 = Color3.fromRGB(22, 22, 30)
        Frame.BorderSizePixel = 0
 
        Frame.Parent = parent

        Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 4)

        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, -10, 0, 20)
        Label.Position = UDim2.new(0, 10, 0, 2)
        Label.BackgroundTransparency = 1
        Label.Text = labelText .. ": " .. tostring(default)
        Label.TextColor3 = Color3.fromRGB(220, 220, 220)
     
        Label.Font = Enum.Font.GothamMedium
        Label.TextSize = 11
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = Frame

        local SliderBtn = Instance.new("TextButton")
        SliderBtn.Size = UDim2.new(1, -20, 0, 8)
        SliderBtn.Position = UDim2.new(0, 10, 0, 26)
        SliderBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
        SliderBtn.Text = ""
      
        SliderBtn.Parent = Frame
        Instance.new("UICorner", SliderBtn).CornerRadius = UDim.new(1, 0)

        local Progress = Instance.new("Frame")
        Progress.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
        Progress.BackgroundColor3 = Config.ThemeColor
        Progress.BorderSizePixel = 0
        Progress.Parent = SliderBtn
        Instance.new("UICorner", Progress).CornerRadius = UDim.new(1, 0)
        table.insert(slidersUIList, Progress)

   
        local snap = false
        local function updateSlider(input)
            local absPos = SliderBtn.AbsolutePosition.X
            local absSize = SliderBtn.AbsoluteSize.X
            local ratio = math.clamp((input.Position.X - absPos) / absSize, 0, 1)
            local value = math.floor(min + (max - min) * ratio)
          
            Progress.Size = UDim2.new(ratio, 0, 1, 0)
            Label.Text = labelText .. ": " .. tostring(value)
            callback(value)
        end

        SliderBtn.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                snap = true
                updateSlider(inp)
            end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                snap = false
            end
        end)
  
        UserInputService.InputChanged:Connect(function(inp)
            if snap and inp.UserInputType == Enum.UserInputType.MouseMovement then
                updateSlider(inp)
            end
        end)
    end

    -- ── Логика Шлейфа (Trails) ───────────────────────────────────

    local function updateLocalTrail()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local oldTrail = char:FindFirstChild("LunaTrailInstance")
        if Config.Trails then
            if not oldTrail then
                local att0 = Instance.new("Attachment")
                att0.Name = "LunaAtt0"
                att0.Position = Vector3.new(0, 1, 0)
                att0.Parent = hrp

                local att1 = Instance.new("Attachment")
                att1.Name = "LunaAtt1"
                att1.Position = Vector3.new(0, -1, 0)
     
                att1.Parent = hrp

                local trail = Instance.new("Trail")
                trail.Name = "LunaTrailInstance"
                trail.Attachment0 = att0
                trail.Attachment1 = att1
              
                trail.Lifetime = 0.5
                trail.LightEmission = 0.8
                trail.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 0),
                    NumberSequenceKeypoint.new(1, 1)
                })
  
                trail.Parent = char
            end
            local trail = char:FindFirstChild("LunaTrailInstance")
            if trail then
                trail.Color = ColorSequence.new(Config.TrailColorValue)
                if Config.TrailMode == "Worm" then
     
                    trail.WidthScale = NumberSequence.new(0.04) 
                    trail.FaceCamera = true 
                else
                    trail.WidthScale = NumberSequence.new(1.0) 
                    trail.FaceCamera = false
                end
            end
        else
            if oldTrail then oldTrail:Destroy() end
            local a0 = hrp:FindFirstChild("LunaAtt0")
            local a1 = hrp:FindFirstChild("LunaAtt1")
            if a0 then a0:Destroy() end
            if a1 then a1:Destroy() end
        end
    end

    -- ── Логика Эффекта призрака (Ghost Effect) ──────────────────────

    task.spawn(function()
        while task.wait(0.1) do
            if Config.GhostEffect and LocalPlayer.Character then
                local char = LocalPlayer.Character
            
                local hum = char:FindFirstChildOfClass("Humanoid")
                local hrp = char:FindFirstChild("HumanoidRootPart")
                
                if hrp and hum and hum.MoveDirection.Magnitude > 0 then
                    char.Archivable = true
            
                    local clone = char:Clone()
                    char.Archivable = false
                   
                    for _, v in ipairs(clone:GetDescendants()) do
                       
                        if v:IsA("LuaSourceContainer") or v:IsA("BillboardGui") or v:IsA("ScreenGui") or v:IsA("Highlight") then
                            v:Destroy()
                        elseif v:IsA("BasePart") then
                            v.CanCollide = false
       
                            v.CanTouch = false 
                            v.CanQuery = false 
                            v.Anchored = true
               
                            v.Material = Enum.Material.ForceField
                            v.Color = Config.GhostColor
                        end
                    end
           
                    
                    local cloneHrp = clone:FindFirstChild("HumanoidRootPart")
                    if cloneHrp then
                        clone.Parent = Workspace
                    
     
