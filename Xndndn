-- 2. ESP
local function applyESP(player)
    if player == LocalPlayer then return end
    local function characterAdded(character)
        if not Config.ESP then return end
        task.wait(0.5)
        if espObjects[player] then espObjects[player]:Destroy() end
        
        local highlight = Instance.new("Highlight")
        highlight.Parent = character
        highlight.Adornee = character
        highlight.FillOpacity = 0.3
        highlight.OutlineOpacity = 1
        
        -- Проверка на убийцу (красный) или выжившего (зеленый)
        if player.Team and (player.Team.Name:lower():find("killer") or player.Team.Name:lower():find("slasher") or player.Team.Name:lower():find("murder")) then
            highlight.FillColor = Color3.fromRGB(255, 40, 40)
            highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
        else
            highlight.FillColor = Color3.fromRGB(40, 255, 120)
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        end
        espObjects[player] = highlight
    end
    player.CharacterAdded:Connect(characterAdded)
    if player.Character then characterAdded(player.Character) end
end

local function toggleESP(state)
    if state then
        for _, p in ipairs(Players:GetPlayers()) do applyESP(p) end
        table.insert(connections, Players.PlayerAdded:Connect(applyESP))
    else
        for p, h in pairs(espObjects) do if h then h:Destroy() end end
        table.clear(espObjects)
    end
end

-- 3. Auto Skill Check
local function setupSkillCheck(state)
    if not state then return end
    local playerGui = LocalPlayer:WaitForChild("PlayerGui", 5)
    if playerGui then
        local connection = playerGui.DescendantAdded:Connect(function(descendant)
            if Config.AutoSkillCheck and (descendant.Name == "SkillCheck" or descendant.Name:find("SkillCheck")) then
                task.wait(0.04) -- Безопасный тайминг под пинг
                local vim = game:GetService("VirtualInputManager")
                vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                task.wait(0.02)
                vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
            end
        end)
        table.insert(connections, connection)
    end
end

