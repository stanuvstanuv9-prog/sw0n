    CreateToggle(VisualsTab, "ESP Names", "ESP")
    CreateToggle(VisualsTab, "Tracers", "Tracers")
    CreateToggle(VisualsTab, "Ghost Effect", "GhostEffect")
    CreateToggle(VisualsTab, "Fullbright", "Fullbright")

    CreateToggle(ExploitsTab, "Perfect Skill Check", "PerfectSkillCheck")
    
