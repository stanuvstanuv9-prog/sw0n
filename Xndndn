-- Проверенные фиксы ESP из прошлой версии
local function applyPlayerESP(player)
    if player == LocalPlayer then return end
    local function onChar(character)
        if espFolders[player] then pcall(function() espFolders[player]:Destroy() end) end
        if not Config.ESP then return end
        
        local root = character:WaitForChild("HumanoidRootPart", 5)
        if not root then return end
        
        local folder = Instance.new("Folder")
        folder.Name = "Luna_ESP"
        folder.Parent = character
        espFolders[player] = folder

        local bb = Instance.new("BillboardGui")
        bb.Size = UDim2.new(0, 160, 0, 40)
        bb.AlwaysOnTop = true
        bb.Adornee = root
        bb.Parent = folder

        local txt = Instance.new("TextLabel")
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Font = Enum.Font.GothamBold
        txt.TextSize = 12
        txt.TextStrokeTransparency = 0
        
        local isKiller = false
        if player.Team and (player.Team.Name:lower():find("kill") or player.Team.Name:lower():find("slash") or player.Team.Name:lower():find("beast")) then
            isKiller = true
        elseif character:FindFirstChildOfClass("Tool") or character:GetAttribute("Role") == "Killer" then
            isKiller = true
        end

        if isKiller then
            txt.Text = "[ МАНЬЯК ]\n" .. player.DisplayName
            txt.TextColor3 = Color3.fromRGB(255, 30, 30)
        else
            txt.Text = "[ Выживший ]\n" .. player.DisplayName
            txt.TextColor3 = Color3.fromRGB(0, 255, 120)
        end
        txt.Parent = bb
    end
    player.CharacterAdded:Connect(onChar)
    if player.Character then onChar(player.Character) end
end

local function toggleESP(state)
    if state then
        for _, p in ipairs(Players:GetPlayers()) do applyPlayerESP(p) end
        table.insert(connections, Players.PlayerAdded:Connect(applyPlayerESP))
    else
        for _, f in pairs(espFolders) do pcall(function() f:Destroy() end) end
        table.clear(espFolders)
    end
end

