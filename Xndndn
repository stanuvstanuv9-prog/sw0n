local function applySkyMod(state)
    if state then
        Lighting.Ambient = Config.SkyColor
        Lighting.OutdoorAmbient = Config.SkyColor
        Lighting.FogColor = Config.SkyColor
    else
        Lighting.Ambient = Color3.fromRGB(128, 128, 128)
        Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
    end
end

-- Функция создания и обновления визуалов для конкретного игрока
local function drawVisuals(player, character)
    if espFolders[player] then pcall(function() espFolders[player]:Destroy() end) end
    if not Config.ESP and not Config.Box then return end
    
    local root = character:WaitForChild("HumanoidRootPart", 5)
    if not root then return end
    
    local folder = Instance.new("Folder")
    folder.Name = "Luna_Visuals"
    folder.Parent = character
    espFolders[player] = folder

    -- Определение роли и выбор цвета
    local isKiller = false
    if player.Team and (player.Team.Name:lower():find("kill") or player.Team.Name:lower():find("slash") or player.Team.Name:lower():find("beast")) then
        isKiller = true
    elseif character:FindFirstChildOfClass("Tool") or character:GetAttribute("Role") == "Killer" or player:GetAttribute("Role") == "Killer" then
        isKiller = true
    end
    
    local themeColor = isKiller and Color3.fromRGB(255, 30, 30) or Color3.fromRGB(0, 255, 120)

    -- Рендеринг текстового ESP
    if Config.ESP then
        local bb = Instance.new("BillboardGui")
        bb.Size = UDim2.new(0, 160, 0, 40)
        bb.AlwaysOnTop = true
        bb.Adornee = root
        bb.Parent = folder

        local txt = Instance.new("TextLabel")
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Font = Enum.Font.GothamBold
        txt.TextSize = 12
        txt.TextStrokeTransparency = 0
        txt.TextColor3 = themeColor
        txt.Text = isKiller and ("[ МАНЬЯК ]\n" .. player.DisplayName) or ("[ Выживший ]\n" .. player.DisplayName)
        txt.Parent = bb
    end

    -- Рендеринг обычных 3D Боксов
    if Config.Box then
        local box = Instance.new("SelectionBox")
        box.Name = "Luna_Box"
        box.Adornee = character
        box.Color3 = themeColor
        box.LineThickness = 0.05
        box.SurfaceTransparency = 1 -- Полностью прозрачные грани, видны только ребра (рамка)
        box.AlwaysOnTop = true
        box.Parent = folder
    end
end

-- Массовое обновление всех игроков при переключении кнопок
local function refreshVisuals()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            drawVisuals(p, p.Character)
        end
    end
end

-- Инициализация отслеживания игроков (подключается один раз при запуске)
local function hookPlayer(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function(character)
        task.wait(0.3) -- Небольшая задержка для загрузки частей тела
        if character.Parent then drawVisuals(player, character) end
    end)
    if player.Character then drawVisuals(player, player.Character) end
end

for _, p in ipairs(Players:GetPlayers()) do hookPlayer(p) end
table.insert(connections, Players.PlayerAdded:Connect(hookPlayer))

-- Функции для тумблеров интерфейса
local function toggleESP(state) refreshVisuals() end
