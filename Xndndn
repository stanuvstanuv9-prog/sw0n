-- [[ АБСОЛЮТНО НОВЫЙ ESP (Через Текстовые Свечения — БЕЗ багов с Highlight) ]] --
local function createBillboardESP(player)
    if player == LocalPlayer then return end
    
    local function removeOldEsp()
        if espFolders[player] then
            pcall(function() espFolders[player]:Destroy() end)
            espFolders[player] = nil
        end
    end

    local function onChar(character)
        removeOldEsp()
        if not Config.ESP then return end
        
        local root = character:WaitForChild("HumanoidRootPart", 5)
        if not root then return end
        
        local folder = Instance.new("Folder")
        folder.Name = "Luna_PlayerESP"
        folder.Parent = character
        espFolders[player] = folder

        -- Текстовый оверхед (Ник + Роль)
        local bb = Instance.new("BillboardGui")
        bb.Size = UDim2.new(0, 200, 0, 50)
        bb.AlwaysOnTop = true
        bb.ExtentsOffset = Vector3.new(0, 3, 0)
        bb.Adornee = root
        bb.Parent = folder

        local txt = Instance.new("TextLabel")
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Font = Enum.Font.GothamBold
        txt.TextSize = 13
        txt.TextStrokeTransparency = 0
        txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        txt.Parent = bb

        -- Жесткая проверка на Маньяка (Killer)
        local isKiller = false
        
        -- 1. Проверка по названию команды
        if player.Team and (player.Team.Name:lower():find("kill") or player.Team.Name:lower():find("slash") or player.Team.Name:lower():find("murder") or player.Team.Name:lower():find("beast")) then
            isKiller = true
        -- 2. Проверка по инструментам/оружию
        elseif character:FindFirstChildOfClass("Tool") or player:WaitForChild("Backpack", 1):FindFirstChildOfClass("Tool") then
            isKiller = true
        -- 3. Проверка по кастомным атрибутам Violence District
        elseif character:GetAttribute("Role") == "Killer" or character:GetAttribute("IsKiller") == true then
            isKiller = true
        end

        if isKiller then
            txt.Text = "[ МАНЬЯК ]\n" .. player.DisplayName
            txt.TextColor3 = Color3.fromRGB(255, 0, 0) -- Ярко-красный
            
            -- Бокс подсветки для маньяка
            local box = Instance.new("BoxHandleAdornment")
            box.Size = Vector3.new(4, 6, 4)
            box.Color3 = Color3.fromRGB(255, 0, 0)
            box.AlwaysOnTop = true
            box.ZIndex = 6
            box.Adornee = root
            box.Transparency = 0.5
            box.Parent = folder
        else
            txt.Text = "[ Выживший ]\n" .. player.DisplayName
            txt.TextColor3 = Color3.fromRGB(0, 255, 150) -- Зеленый
        end
    end

    player.CharacterAdded:Connect(onChar)
    if player.Character then onChar(player.Character) end
end

local function toggleESP(state)
    if state then
        for _, p in ipairs(Players:GetPlayers()) do createBillboardESP(p) end
        table.insert(connections, Players.PlayerAdded:Connect(createBillboardESP))
    else
        for _, folder in pairs(espFolders) do pcall(function() folder:Destroy() end) end
        table.clear(espFolders)
    end
end

-- [[ НОВЫЙ ESP НА ОБЪЕКТЫ (Генераторы / Палеты) ]] --
local function toggleObjectESP(state)
    if state then
        table.insert(connections, RunService.Heartbeat:Connect(function()
            if not Config.ObjectESP then return end
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("Model") and not obj:FindFirstChild("LunaObj") then
                    local name = obj.Name:lower()
                    local isGen = name:find("gen") or name:find("motor") or name:find("engine")
                    local isPallet = name:find("pallet") or name:find("plate") or name:find("board")
                    
                    if isGen or isPallet then
                        local folder = Instance.new("Folder")
                        folder.Name = "LunaObj"
                        folder.Parent = obj
                        
                        local bb = Instance.new("BillboardGui")
                        bb.Size = UDim2.new(0, 150, 0, 30)
                        bb.AlwaysOnTop = true
                        bb.Adornee = obj:FindFirstChildOfClass("BasePart") or obj
                        bb.Parent = folder
                        
                        local txt = Instance.new("TextLabel")
                        txt.Size = UDim2.new(1, 0, 1, 0)
                        txt.BackgroundTransparency = 1
                        txt.Font = Enum.Font.GothamBold
                        txt.TextSize = 11
                        txt.TextStrokeTransparency = 0
                        txt.Text = isGen and "[ ГЕНЕРАТОР ]" or "[ ПАЛЕТА ]"
                        txt.TextColor3 = isGen and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(160, 120, 90)
                        txt.Parent = bb
                    end
                end
            end
        end))
    else
        for _, obj in ipairs(Workspace:GetDescendants()) do
            local f = obj:FindFirstChild("LunaObj")
            if f then pcall(function() f:Destroy() end) end
        end
    end
end

-- [[ АВТО-СКИЛЛЧЕК (Поиск по всем GUI игры) ]] --
local function toggleSkillCheck(state)
    if not state then return end
    local pGui = LocalPlayer:WaitForChild("PlayerGui")
    
    local function scan(descendant)
        if Config.AutoSkillCheck and descendant:IsA("GuiObject") then
            local n = descendant.Name:lower()
            -- Проверяем вообще все возможные триггеры зоны успеха в разных плейсах
            if n:find("zone") or n:find("success") or n:find("perfect") or n:find("check") or n:find("bar") then
                task.wait(0.01)
                local vim = game:GetService("VirtualInputManager")
                vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                task.wait(0.01)
                vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
            end
        end
    end
    table.insert(connections, pGui.DescendantAdded:Connect(scan))
end

-- [[ ОСТАЛЬНЫЕ ФУНКЦИИ ]] --
table.insert(connections, RunService.RenderStepped:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local hum = LocalPlayer.Character.Humanoid
        if Config.Speedhack then hum.WalkSpeed = Config.SpeedValue end
        if Config.NoFall and hum:GetState() == Enum.HumanoidStateType.Freefall then
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
    end
end))

table.insert(connections, RunService.Stepped:Connect(function()
    if Config.Noclip and LocalPlayer.Character then
        for _, part in ipairs(LocalPlayer.Character:GetChildren()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end))

