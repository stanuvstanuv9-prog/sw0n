        if not state then
            Lighting.Ambient = originalLighting.Ambient Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
            Lighting.Brightness = originalLighting.Brightness Lighting.ClockTime = originalLighting.ClockTime
