local function applyWallMod(state)
    if state then
        Lighting.Ambient = Config.WallColorValue
    else
        Lighting.Ambient = originalLighting.Ambient
    end
end

local function applySkyMod(state)
    if state then
        Lighting.OutdoorAmbient = Config.SkyColorValue
        Lighting.ColorShift_Top = Config.SkyColorValue
        Lighting.FogColor = Config.SkyColorValue
    else
        Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
        Lighting.ColorShift_Top = originalLighting.ColorShift_Top
        Lighting.FogColor = Color3.fromRGB(128, 128, 128)
    end
end

local function updateParticles()
    if Config.ParticleColor then
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") then
                local name = obj.Name:lower()
                if name:find("geometric") or name:find("snow") or name:find("particle") then
                    obj.Color = ColorSequence.new(Config.ParticleColorValue)
                end
            end
        end
    end
end

