    ContentFrame.Parent = MainFrame

    -- ── Tabs ────────────────────────────────────────────────────────────────

    local function SwitchToTab(tabName)
        for name, frame in pairs(tabs) do
            frame.Visible = (name == tabName)
        end
        for name, btn in pairs(tabButtons) do
            btn.TextColor3 = (name == tabName)
                and Color3.fromRGB(0, 180, 255)
                or  Color3.fromRGB(150, 150, 150)
        end
    end

    local function CreateTab(name)
        local TabButton = Instance.new("TextButton")
        TabButton.Size = UDim2.new(1, 0, 0, 32)
        TabButton.BackgroundTransparency = 1
        TabButton.Text = "  " .. name
        TabButton.TextColor3 = Color3.fromRGB(150, 150, 150)
        TabButton.Font = Enum.Font.GothamMedium
        TabButton.TextSize = 13
        TabButton.TextXAlignment = Enum.TextXAlignment.Left
        TabButton.Parent = TabBtnContainer
        tabButtons[name] = TabButton

        local Page = Instance.new("ScrollingFrame")
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.CanvasSize = UDim2.new(0, 0, 0, 0)
        Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
        Page.ScrollBarThickness = 3
        Page.ScrollBarImageColor3 = Color3.fromRGB(0, 180, 255)
        Page.Parent = ContentFrame
        tabs[name] = Page

        local PageLayout = Instance.new("UIListLayout")
        PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        PageLayout.Padding = UDim.new(0, 6)
        PageLayout.Parent = Page

        local PagePadding = Instance.new("UIPadding")
        PagePadding.PaddingTop = UDim.new(0, 4)
        PagePadding.Parent = Page

        TabButton.MouseButton1Click:Connect(function()
            SwitchToTab(name)
        end)

        return Page
    end

    local MainTab    = CreateTab("Main")
    local VisualsTab = CreateTab("Visuals")
    local ExploitsTab = CreateTab("Exploits")
    SwitchToTab("Main")

    -- ── Компоненты ───────────────────────────

    local function CreateToggle(parent, labelText, propName, callback, hasColor, colorPropName, colorCallback)
        local Frame = Instance.new("Frame")
        Frame.Size = UDim2.new(1, -5, 0, 35)
        Frame.BackgroundColor3 = Color3.fromRGB(22, 22, 30)
        Frame.BorderSizePixel = 0
        Frame.ClipsDescendants = true
        Frame.Parent = parent

        local FCorn = Instance.new("UICorner")
        FCorn.CornerRadius = UDim.new(0, 4)
        FCorn.Parent = Frame

        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, -90, 0, 35)
        Label.Position = UDim2.new(0, 10, 0, 0)
        Label.BackgroundTransparency = 1
        Label.Text = labelText
        Label.TextColor3 = Color3.fromRGB(220, 220, 220)
        Label.Font = Enum.Font.GothamMedium
        Label.TextSize = 12
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = Frame

        local Btn = Instance.new("TextButton")
        Btn.Size = UDim2.new(0, 35, 0, 16)
        Btn.Position = UDim2.new(1, -45, 0, 9)
        Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
        Btn.Text = ""
        Btn.Parent = Frame

        local BCorn = Instance.new("UICorner")
        BCorn.CornerRadius = UDim.new(1, 0)
        BCorn.Parent = Btn

        Btn.MouseButton1Click:Connect(function()
            Config[propName] = not Config[propName]
            TweenService:Create(Btn, TweenInfo.new(0.15), {
                BackgroundColor3 = Config[propName]
                    and Color3.fromRGB(0, 180, 255)
                    or  Color3.fromRGB(45, 45, 55)
            }):Play()
            if callback then callback(Config[propName]) end
        end)

        if hasColor and colorPropName then
            local ColorBtn = Instance.new("TextButton")
            ColorBtn.Size = UDim2.new(0, 16, 0, 16)
            ColorBtn.Position = UDim2.new(1, -75, 0, 9)
            ColorBtn.BackgroundColor3 = Config[colorPropName]
            ColorBtn.Text = ""
            ColorBtn.Parent = Frame

            local CCorn = Instance.new("UICorner")
            CCorn.CornerRadius = UDim.new(0, 4)
            CCorn.Parent = ColorBtn

            local Palette = Instance.new("Frame")
            Palette.Size = UDim2.new(1, -20, 0, 100)
            Palette.Position = UDim2.new(0, 10, 0, 35)
            Palette.BackgroundTransparency = 1
            Palette.Parent = Frame

            local SVMap = Instance.new("TextButton")
            SVMap.Size = UDim2.new(1, -30, 1, -10)
            SVMap.Position = UDim2.new(0, 0, 0, 5)
            SVMap.Text = ""
            SVMap.AutoButtonColor = false
            SVMap.Parent = Palette
            Instance.new("UICorner", SVMap).CornerRadius = UDim.new(0, 4)

            local WhiteOv = Instance.new("Frame", SVMap)
            WhiteOv.Size = UDim2.new(1,0,1,0)
            WhiteOv.BackgroundColor3 = Color3.new(1,1,1)
            Instance.new("UICorner", WhiteOv).CornerRadius = UDim.new(0, 4)
            local wg = Instance.new("UIGradient", WhiteOv)
            wg.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1)})

            local BlackOv = Instance.new("Frame", SVMap)
            BlackOv.Size = UDim2.new(1,0,1,0)
            BlackOv.BackgroundColor3 = Color3.new(0,0,0)
            Instance.new("UICorner", BlackOv).CornerRadius = UDim.new(0, 4)
            local bg = Instance.new("UIGradient", BlackOv)
            bg.Rotation = 90
            bg.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(1,0)})

            local SVMarker = Instance.new("Frame", BlackOv)
            SVMarker.Size = UDim2.new(0,8,0,8)
            SVMarker.AnchorPoint = Vector2.new(0.5, 0.5)
            SVMarker.BackgroundColor3 = Color3.new(1,1,1)
            Instance.new("UICorner", SVMarker).CornerRadius = UDim.new(1,0)
            local sstr = Instance.new("UIStroke", SVMarker)
            sstr.Color = Color3.new(0,0,0)

            local HueMap = Instance.new("TextButton")
            HueMap.Size = UDim2.new(0, 20, 1, -10)
            HueMap.Position = UDim2.new(1, -20, 0, 5)
            HueMap.Text = ""
            HueMap.AutoButtonColor = false
            HueMap.BackgroundColor3 = Color3.new(1,1,1)
            HueMap.Parent = Palette
            Instance.new("UICorner", HueMap).CornerRadius = UDim.new(0, 4)

            local hg = Instance.new("UIGradient", HueMap)
            hg.Rotation = 90
            hg.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255,0,0)),
                ColorSequenceKeypoint.new(0.167, Color3.fromRGB(255,255,0)),
                ColorSequenceKeypoint.new(0.333, Color3.fromRGB(0,255,0)),
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0,255,255)),
                ColorSequenceKeypoint.new(0.667, Color3.fromRGB(0,0,255)),
                ColorSequenceKeypoint.new(0.833, Color3.fromRGB(255,0,255)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(255,0,0))
            })

            local HueMarker = Instance.new("Frame", HueMap)
            HueMarker.Size = UDim2.new(1, 4, 0, 4)
            HueMarker.AnchorPoint = Vector2.new(0.5, 0.5)
            HueMarker.BackgroundColor3 = Color3.new(1,1,1)
            Instance.new("UIStroke", HueMarker).Color = Color3.new(0,0,0)

            local h, s, v = Config[colorPropName]:ToHSV()
            SVMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)

            local function UpdateColorParams()
                local newColor = Color3.fromHSV(h, s, v)
                Config[colorPropName] = newColor
                ColorBtn.BackgroundColor3 = newColor
                SVMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)

                HueMarker.Position = UDim2.new(0.5, 0, 1 - h, 0)
                SVMarker.Position = UDim2.new(s, 0, 1 - v, 0)

                if colorCallback then colorCallback(newColor) end
            end
            UpdateColorParams()

            local draggingSV, draggingHue = false, false
            local function handleInput(input, isHue)
                if isHue then
                    local y = math.clamp(input.Position.Y - HueMap.AbsolutePosition.Y, 0, HueMap.AbsoluteSize.Y)
                    h = 1 - (y / HueMap.AbsoluteSize.Y)
                else
                    local x = math.clamp(input.Position.X - SVMap.AbsolutePosition.X, 0, SVMap.AbsoluteSize.X)
                    local y = math.clamp(input.Position.Y - SVMap.AbsolutePosition.Y, 0, SVMap.AbsoluteSize.Y)
                    s = x / SVMap.AbsoluteSize.X
                    v = 1 - (y / SVMap.AbsoluteSize.Y)
                end
                UpdateColorParams()
            end

            SVMap.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSV = true; handleInput(inp, false)
                end
            end)
            HueMap.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingHue = true; handleInput(inp, true)
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSV = false; draggingHue = false
                end
            end)
            UserInputService.InputChanged:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseMovement then
                    if draggingSV then handleInput(inp, false) end
                    if draggingHue then handleInput(inp, true) end
                end
            end)

            local isExpanded = false
            ColorBtn.MouseButton1Click:Connect(function()
                isExpanded = not isExpanded
                TweenService:Create(Frame, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Size = isExpanded and UDim2.new(1, -5, 0, 135) or UDim2.new(1, -5, 0, 35)
                }):Play()
            end)
        end
    end

    local function CreateSlider(parent, labelText, min, max, default, callback)
        local Frame = Instance.new("Frame")
        Frame.Size = UDim2.new(1, -5, 0, 45)
        Frame.BackgroundColor3 = Color3.fromRGB(22, 22, 30)
        Frame.BorderSizePixel = 0
        Frame.Parent = parent

        local FCorn = Instance.new("UICorner")
        FCorn.CornerRadius = UDim.new(0, 4)
        FCorn.Parent = Frame

        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, -10, 0, 20)
        Label.Position = UDim2.new(0, 10, 0, 2)
        Label.BackgroundTransparency = 1
        Label.Text = labelText .. ": " .. tostring(default)
        Label.TextColor3 = Color3.fromRGB(220, 220, 220)
        Label.Font = Enum.Font.GothamMedium
        Label.TextSize = 11
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = Frame

        local SliderBtn = Instance.new("TextButton")
        SliderBtn.Size = UDim2.new(1, -20, 0, 8)
        SliderBtn.Position = UDim2.new(0, 10, 0, 26)
        SliderBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
        SliderBtn.Text = ""
        SliderBtn.Parent = Frame
        Instance.new("UICorner", SliderBtn).CornerRadius = UDim.new(1, 0)

        local Progress = Instance.new("Frame")
        Progress.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
        Progress.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
        Progress.BorderSizePixel = 0
        Progress.Parent = SliderBtn
        Instance.new("UICorner", Progress).CornerRadius = UDim.new(1, 0)

        local snap = false
        local function updateSlider(input)
            local absPos = SliderBtn.AbsolutePosition.X
            local absSize = SliderBtn.AbsoluteSize.X
            local ratio = math.clamp((input.Position.X - absPos) / absSize, 0, 1)
            local value = math.floor(min + (max - min) * ratio)
            
            Progress.Size = UDim2.new(ratio, 0, 1, 0)
            Label.Text = labelText .. ": " .. tostring(value)
            callback(value)
        end

        SliderBtn.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                snap = true
                updateSlider(inp)
            end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                snap = false
            end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if snap and inp.UserInputType == Enum.UserInputType.MouseMovement then
                updateSlider(inp)
            end
        end)
    end

    -- ── Логика Шлейфа (Trails) ───────────────────────────────────

    local function updateLocalTrail()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local oldTrail = char:FindFirstChild("LunaTrailInstance")
        if Config.Trails then
            if not oldTrail then
                local att0 = Instance.new("Attachment")
                att0.Name = "LunaAtt0"
                att0.Position = Vector3.new(0, 1, 0)
                att0.Parent = hrp

                local att1 = Instance.new("Attachment")
                att1.Name = "LunaAtt1"
                att1.Position = Vector3.new(0, -1, 0)
                att1.Parent = hrp

                local trail = Instance.new("Trail")
                trail.Name = "LunaTrailInstance"
                trail.Attachment0 = att0
                trail.Attachment1 = att1
                trail.Lifetime = 0.5
        trail.LightEmission = 0.8
                trail.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 0),
                    NumberSequenceKeypoint.new(1, 1)
                })
                trail.Parent = char
            end
            local trail = char:FindFirstChild("LunaTrailInstance")
            if trail then
                trail.Color = ColorSequence.new(Config.TrailColorValue)
                if Config.TrailMode == "Worm" then
                    trail.WidthScale = NumberSequence.new(0.04) 
                    trail.FaceCamera = true 
                else
                    trail.WidthScale = NumberSequence.new(1.0) 
                    trail.FaceCamera = false
                end
            end
        else
            if oldTrail then oldTrail:Destroy() end
            local a0 = hrp:FindFirstChild("LunaAtt0")
            local a1 = hrp:FindFirstChild("LunaAtt1")
            if a0 then a0:Destroy() end
            if a1 then a1:Destroy() end
        end
    end

    -- ── Логика Эффекта призрака (Ghost Effect) ──────────────────────

    task.spawn(function()
        while task.wait(0.1) do
            if Config.GhostEffect and LocalPlayer.Character then
                local char = LocalPlayer.Character
                local hum = char:FindFirstChildOfClass("Humanoid")
                local hrp = char:FindFirstChild("HumanoidRootPart")
                
                if hrp and hum and hum.MoveDirection.Magnitude > 0 then
                    char.Archivable = true
                    local clone = char:Clone()
                    char.Archivable = false
                   
                    for _, v in ipairs(clone:GetDescendants()) do
                        if v:IsA("LuaSourceContainer") or v:IsA("BillboardGui") or v:IsA("ScreenGui") or v:IsA("Highlight") then
                            v:Destroy()
                        elseif v:IsA("BasePart") then
                            v.CanCollide = false
                            v.Anchored = true
                            v.Material = Enum.Material.ForceField
                            v.Color = Config.TrailColorValue or Color3.fromRGB(0, 180, 255)
                        end
                    end
                    
                    local cloneHrp = clone:FindFirstChild("HumanoidRootPart")
                    if cloneHrp then
                        clone.Parent = Workspace
                        
                        task.spawn(function()
                            for i = 0, 1, 0.1 do
                                task.wait(0.04)
                                for _, part in ipairs(clone:GetChildren()) do
                                    if part:IsA("BasePart") then
                                        part.Transparency = i
                                    elseif part:IsA("Accessory") and part:FindFirstChild("Handle") then
                                        part.Handle.Transparency = i
                                    end
                                end
                            end
                            clone:Destroy()
                        end)
                    else
                        clone:Destroy()
                    end
                end
            end
        end
    end)

    -- ── Рендер лупы коннектов ────────────────────────────────────

    table.insert(connections, RunService.RenderStepped:Connect(function(dt)
        if not LocalPlayer.Character then return end
        local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hrp and hum and hum.MoveDirection.Magnitude > 0 and Config.CFrameSpeed then
            local spd = Config.SpeedValue
            if Config.AutoSprint and isSprinting then spd = spd * 1.8 end
            hrp.CFrame = hrp.CFrame + (hum.MoveDirection * (spd * dt * 10))
        end
    end))

    table.insert(connections, RunService.RenderStepped:Connect(function()
        if not LocalPlayer.Character then return end
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        if Config.NoFall and hum:GetState() == Enum.HumanoidStateType.Freefall then
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
        if not Config.CFrameSpeed and Config.AutoSprint then
            if isSprinting then
                hum.WalkSpeed = Config.SprintWalkSpeed
            else
                if hum.WalkSpeed == Config.SprintWalkSpeed then
                    hum.WalkSpeed = Config.NormalWalkSpeed
                end
            end
        end
    end))

    table.insert(connections, RunService.Stepped:Connect(function()
        if Config.Noclip and LocalPlayer.Character then
            for _, part in ipairs(LocalPlayer.Character:GetChildren()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end))

    table.insert(connections, RunService.RenderStepped:Connect(function()
        if Camera and Camera.FieldOfView ~= Config.FOVValue then
            Camera.FieldOfView = Config.FOVValue
        end
    end))

    table.insert(connections, RunService.RenderStepped:Connect(function()
        if Config.Fullbright then
            Lighting.Ambient    = Color3.fromRGB(255, 255, 255)
            Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
            Lighting.Brightness     = 3
            Lighting.ClockTime      = 14
            Lighting.GlobalShadows  = false
        end
        if Config.NoFog then
            Lighting.FogEnd         = 999999
        end
    end))

    -- ── AntiAFK ─────────────────────────────────────────────────────────────

    local antiAfkConnection
    local function toggleAntiAFK(state)
        if state then
            if not antiAfkConnection then
                antiAfkConnection = LocalPlayer.Idled:Connect(function()
                    pcall(function()
                        VirtualUser:CaptureController()
                        VirtualUser:ClickButton2(Vector2.new(0, 0))
                    end)
                end)
            end
        else
            if antiAfkConnection then
                antiAfkConnection:Disconnect()
                antiAfkConnection = nil
            end
        end
    end

    local function toggleFullbright(state)
        if not state then
