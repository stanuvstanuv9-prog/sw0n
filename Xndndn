                local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if hum and not Config.CFrameSpeed and hum.WalkSpeed == Config.SprintWalkSpeed then hum.WalkSpeed = Config.NormalWalkSpeed end
            end
        end
    end)

    -- ЛОГИКА ИЗМЕНЕНИЯ ЦВЕТА СТЕН 1 И СТЕН 2
    local function applyWallColor1(state) 
        Lighting.Ambient = state and Config.WallColor1Value or originalLighting.Ambient 
    end
    local function applyWallColor2(state)
        if state then
            Lighting.OutdoorAmbient, Lighting.ColorShift_Top, Lighting.FogColor = Config.WallColor2Value, Config.WallColor2Value, Config.WallColor2Value
        else
            Lighting.OutdoorAmbient, Lighting.ColorShift_Top, Lighting.FogColor = originalLighting.OutdoorAmbient, originalLighting.ColorShift_Top, originalLighting.FogColor
        end
    end

    local function scansForWeapons(container)
        if not container then return false end
        for _, item in ipairs(container:GetChildren()) do
            if item:IsA("Tool") then
                local iName = item.Name:lower()
                if not iName:find("flashlight") and not iName:find("medkit") and not iName:find("cola") and not iName:find("camera") then return true end
            end
        end
        return false
    end

    local function checkIsKiller(player, character)
        if not player then return false end
        if player.Team then
            local tName = player.Team.Name:lower()
            if tName:find("kill") or tName:find("slash") or tName:find("beast") or tName:find("murder") or tName:find("hunter") then return true end
        end
        if player:GetAttribute("Role") == "Killer" or player:GetAttribute("IsKiller") == true then return true end
        if character and (character:GetAttribute("Role") == "Killer" or character:GetAttribute("IsKiller") == true) then return true end
        if character and scansForWeapons(character) then return true end
        if player:FindFirstChild("Backpack") and scansForWeapons(player.Backpack) then return true end
        return false
    end

