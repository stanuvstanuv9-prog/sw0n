            if not bb then
                bb = Instance.new("BillboardGui", folder) bb.Name = "LunaBB" bb.AlwaysOnTop = true bb.Size = UDim2.new(0, 120, 0, 40) bb.StudsOffset = Vector3.new(0, 3, 0) bb.Adornee = hrp
