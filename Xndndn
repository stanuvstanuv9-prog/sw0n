                Color3.fromRGB(0, 0, 255), Color3.fromRGB(255, 255, 0),
                Color3.fromRGB(255, 0, 255), Color3.fromRGB(0, 255, 255),
                Color3.fromRGB(255, 255, 255), Color3.fromRGB(120, 100, 255)
            }
            for _, col in ipairs(colors) do
                local Choice = Instance.new("TextButton")
                Choice.Size = UDim2.new(0, 20, 0, 20)
                Choice.BackgroundColor3 = col
                Choice.Text = ""
                Choice.ZIndex = 11
                Choice.Parent = Palette

                local ChoiceCorn = Instance.new("UICorner")
                ChoiceCorn.CornerRadius = UDim.new(0, 3)
                ChoiceCorn.Parent = Choice

                Choice.MouseButton1Click:Connect(function()
                    Config[colorPropName] = col
                    ColorBtn.BackgroundColor3 = col
                    Palette.Visible = false
                    if colorCallback then colorCallback(col) end
                end)
            end

            ColorBtn.MouseButton1Click:Connect(function()
                Palette.Visible = not Palette.Visible
                if Palette.Visible then
                    Palette.Parent = ScreenGui
