                Config.FOVValue = 95
                FOVBtn.Text = "95 FOV"
            elseif Config.FOVValue == 95 then
                Config.FOVValue = 110
                FOVBtn.Text = "110 FOV"
            else
                Config.FOVValue = 70
                FOVBtn.Text = "70 (Default)"
            end
        end)
    end

