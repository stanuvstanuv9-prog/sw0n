                    if not existingSnow then
                        local a = Instance.new("Attachment", hrp)
                        a.Name = "LunaSnowEmitter"
                        a.Position = Vector3.new(0, 10, 0)
                        local pe = Instance.new("ParticleEmitter", a)
                        pe.Texture = "rbxassetid://243660364"
                        pe.Rate = 50
                        pe.Lifetime = NumberRange.new(2, 4)
                        pe.Speed = NumberRange.new(5, 10)
                        pe.EmissionDirection = Enum.NormalId.Bottom
                        pe.SpreadAngle = Vector2.new(180, 180)
                    end
                else
                    if existingSnow then
                        existingSnow:Destroy()
                    end
                end
            end
        end
    end)

    task.spawn(function()
        while task.wait(0.05) do
            if not Config.PerfectSkillCheck then continue end
            local pgui = LocalPlayer:FindFirstChild("PlayerGui")
            if not pgui then continue end
            for _, sg in ipairs(pgui:GetChildren()) do
                local function findSkillCheck(obj)
                    for _, child in ipairs(obj:GetDescendants()) do
                        local n = child.Name:lower()
                        if n:find("skillcheck") or n:find("skill_check") or n:find("greatzone") then
                            if child:IsA("Frame") and child.Visible then
                                local vInput = Instance.new("InputObject")
                                vInput.KeyCode = Enum.KeyCode.Space
                                vInput.UserInputType = Enum.UserInputType.Keyboard
                                UserInputService.InputBegan:Fire(vInput, false)
                            end
                        end
                    end
                end
                findSkillCheck(sg)
            end
        end
    end)

