-- [[ СВЕРХТОЧНАЯ ДИНАМИЧЕСКАЯ СИСТЕМА ОПРЕДЕЛЕНИЯ РОЛИ ]] --
local function checkIsKiller(player, character)
    if not player then return false end
    
    -- 1. Проверка по названию команды
    if player.Team then
        local tName = player.Team.Name:lower()
        if tName:find("kill") or tName:find("slash") or tName:find("beast") or tName:find("murder") or tName:find("hunter") or tName:find("monster") then
            return true
        end
    end
    
    -- 2. Проверка по встроенным атрибутам Roblox (работает во многих плейсах)
    if player:GetAttribute("Role") == "Killer" or player:GetAttribute("IsKiller") == true then return true end
    if character and (character:GetAttribute("Role") == "Killer" or character:GetAttribute("IsKiller") == true) then return true end
    
    -- 3. Проверка по оружию в руках или инвентаре (исключая мирные предметы)
    local function scansForWeapons(container)
        if not container then return false end
        for _, item in ipairs(container:GetChildren()) do
            if item:IsA("Tool") then
                local iName = item.Name:lower()
                if not iName:find("flashlight") and not iName:find("medkit") and not iName:find("cola") and not iName:find("camera") and not iName:find("card") then
                    return true -- Если у него в руках оружие (не фонарик/аптечка), то он маньяк
                end
            end
        end
        return false
    end
    
    if character and scansForWeapons(character) then return true end
    if player:FindFirstChild("Backpack") and scansForWeapons(player.Backpack) then return true end
    
    return false
end

-- [[ ЕДИНЫЙ ПОТОК ОБНОВЛЕНИЯ ВИЗУАЛОВ (БЕЗ ЛАГОВ И ОШИБОК) ]] --
task.spawn(function()
    while task.wait(0.3) do -- Постоянный цикл обновления каждые 0.3 сек
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local character = player.Character
                if character and character:FindFirstChild("HumanoidRootPart") and character:FindFirstChildOfClass("Humanoid") then
                    
                    -- Создаем или находим контейнер для наших чит-объектов внутри игрока
                    local folder = character:FindFirstChild("Luna_Visuals_Container")
                    if not folder then
                        folder = Instance.new("Folder")
                        folder.Name = "Luna_Visuals_Container"
                        folder.Parent = character
                    end
                    
                    -- Запускаем точную проверку роли в реальном времени
                    local isKiller = checkIsKiller(player, character)
                    local currentColor = isKiller and Color3.fromRGB(255, 30, 30) or Color3.fromRGB(0, 255, 120)
                    local currentText = isKiller and "[ МАНЬЯК ]" or "[ Выживший ]"
                    
                    -- ОБРАБОТКА НИК ESP (НАДПИСИ)
                    local textESP = folder:FindFirstChild("Luna_Text")
                    if Config.ESP then
                        if not textESP then
                            textESP = Instance.new("BillboardGui")
                            textESP.Name = "Luna_Text"
                            textESP.Size = UDim2.new(0, 160, 0, 40)
                            textESP.AlwaysOnTop = true
                            
                            local label = Instance.new("TextLabel")
                            label.Name = "Label"
                            label.Size = UDim2.new(1, 0, 1, 0)
                            label.BackgroundTransparency = 1
                            label.Font = Enum.Font.GothamBold
                            label.TextSize = 12
                            label.TextStrokeTransparency = 0
                            label.Parent = textESP
                            
                            textESP.Parent = folder
                        end
                        textESP.Adornee = character.HumanoidRootPart
                        textESP.Label.Text = currentText .. "\n" .. player.DisplayName
                        textESP.Label.TextColor3 = currentColor
                    else
                        if textESP then textESP:Destroy() end
                    end
                    
                    -- ОБРАБОТКА БОКС ESP (ПОДДСВЕТКА СТЕН)
                    local boxESP = folder:FindFirstChild("Luna_Highlight")
                    if Config.Box then
                        if not boxESP then
                            boxESP = Instance.new("Highlight")
                            boxESP.Name = "Luna_Highlight"
                            boxESP.FillTransparency = 1 -- Прозрачный внутри (только рамка-бокс)
                            boxESP.OutlineTransparency = 0
                            boxESP.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                            boxESP.Parent = folder
                        end
                        boxESP.Adornee = character
                        boxESP.OutlineColor = currentColor
                    else
                        if boxESP then boxESP:Destroy() end
                    end
                    
                end
            end
        end
    end
end)

