    local function scansForWeapons(container)
        if not container then return false end
        for _, item in ipairs(container:GetChildren()) do
            if item:IsA("Tool") then
                local iName = item.Name:lower()
                if not iName:find("flashlight") and not iName:find("medkit")
                   and not iName:find("cola")      and not iName:find("camera") then
                    return true
                end
            end
        end
        return false
    end

    local function checkIsKiller(player, character)
        if not player then return false end
        if player.Team then
            local tName = player.Team.Name:lower()
            if tName:find("kill") or tName:find("slash") or tName:find("beast")
               or tName:find("murder") or tName:find("hunter") then
                return true
            end
        end
        if player:GetAttribute("Role") == "Killer" or player:GetAttribute("IsKiller") == true then
            return true
        end
        if character and (character:GetAttribute("Role") == "Killer"
            or character:GetAttribute("IsKiller") == true) then
            return true
        end
        if character and scansForWeapons(character) then return true end
        if player:FindFirstChild("Backpack") and scansForWeapons(player.Backpack) then return true end
        return false
    end

    -- ── Функция ТП к упавшим союзникам ───────────────────────────────────────
    local function TeleportToClosestDowned()
        local character = LocalPlayer.Character
        if not character then return end
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local closestDowned, closestDist = nil, math.huge

        for _, player in ipairs(Players:GetPlayers()) do
            -- Пропускаем себя
            if player == LocalPlayer then continue end
            
            local pChar = player.Character
            if not pChar then continue end
            
            local pHrp = pChar:FindFirstChild("HumanoidRootPart")
            local pHum = pChar:FindFirstChildOfClass("Humanoid")
            if not pHrp or not pHum then continue end

            -- Проверяем, что игрок НЕ маньяк
            if checkIsKiller(player, pChar) then continue end

            -- Условие «падения» выжившего: здоровье меньше 15 ИЛИ персонаж лежит
            local isDowned = (pHum.Health > 0 and pHum.Health <= 15) 
                or pHum:GetState() == Enum.HumanoidStateType.Ragdoll 
                or pChar:GetAttribute("IsDowned") == true

            if isDowned then
                local dist = (pHrp.Position - hrp.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closestDowned = pHrp
                end
            end
        end

        if closestDowned then
            hrp.CFrame = CFrame.new(closestDowned.Position + Vector3.new(0, 3, 0))
        else
            warn("[Luna V4]: Раненых союзников на карте не найдено.")
        end
    end

