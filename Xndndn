            ColorBtn.Parent = Frame
            Instance.new("UICorner", ColorBtn).CornerRadius = UDim.new(0, 4)
            CreateColorPalette(Frame, colorPropName, ColorBtn, colorCallback)

            local expanded = false
            ColorBtn.MouseButton1Click:Connect(function()
                expanded = not expanded
                TweenService:Create(Frame, TweenInfo.new(0.2), {Size = expanded and UDim2.new(1,-5,0,135) or UDim2.new(1,-5,0,35)}):Play()
            end)
        end
    end

    local function CreatePureColorPicker(parent, labelText, colorPropName, colorCallback)
        local Frame = Instance.new("Frame")
        Frame.Size = UDim2.new(1, -5, 0, 35)
        Frame.BackgroundColor3 = Color3.fromRGB(22, 22, 30)
        Frame.ClipsDescendants = true
        Frame.Parent = parent
