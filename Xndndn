            CCorn.Parent = ColorBtn

            local Palette = Instance.new("Frame")
            Palette.Size = UDim2.new(0, 100, 0, 56)
            Palette.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
            Palette.BorderSizePixel = 0
            Palette.ZIndex = 10
            Palette.Visible = false

