-- Умный авто-скиллчек, целящийся строго в Perfect/White Zone
local function togglePerfectSkillCheck(state)
    if not state then return end
    local pGui = LocalPlayer:WaitForChild("PlayerGui")
    
    local function scanUI(descendant)
        if Config.PerfectSkillCheck and descendant:IsA("GuiObject") then
            local name = descendant.Name:lower()
            -- Ищем триггер идеального попадания (обычно разработчики называют его Perfect, Great или White)
            if name:find("perfect") or name:find("great") or name:find("white") or name:find("bonus") then
                -- Небольшое смещение тайминга для идеального эмулирования нажатия прямо внутри белой зоны
                task.wait(0.005) 
                local vim = game:GetService("VirtualInputManager")
                vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                task.wait(0.01)
                vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
            end
        end
    end
    table.insert(connections, pGui.DescendantAdded:Connect(scanUI))
end

CreateToggle(ExploitsTab, "Perfect Auto-Skillcheck (Белая зона)", "PerfectSkillCheck", togglePerfectSkillCheck)


