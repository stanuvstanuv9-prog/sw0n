        ColorBtn.Size = UDim2.new(0, 26, 0, 16)
        ColorBtn.Position = UDim2.new(1, -36, 0, 9)
        ColorBtn.BackgroundColor3 = Config[colorPropName]
        ColorBtn.Text = ""
        ColorBtn.Parent = Frame
        Instance.new("UICorner", ColorBtn).CornerRadius = UDim.new(0, 4)
        CreateColorPalette(Frame, colorPropName, ColorBtn, colorCallback)

        local expanded = false
        ColorBtn.MouseButton1Click:Connect(function()
            expanded = not expanded
            TweenService:Create(Frame, TweenInfo.new(0.2), {Size = expanded and UDim2.new(1,-5,0,135) or UDim2.new(1,-5,0,35)}):Play()
        end)
    end

    local function CreateSlider(parent, labelText, min, max, default, callback)
        local Frame = Instance.new("Frame")
        Frame.Size = UDim2.new(1, -5, 0, 45)
        Frame.BackgroundColor3 = Color3.fromRGB(22, 22, 30)
        Frame.Parent = parent
        Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 4)

        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, -10, 0, 20)
        Label.Position = UDim2.new(0, 10, 0, 2)
        Label.BackgroundTransparency = 1
        Label.Text = labelText .. ": " .. tostring(default)
        Label.TextColor3 = Color3.fromRGB(220, 220, 220)
        Label.Font = Enum.Font.GothamMedium
        Label.TextSize = 11
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = Frame

        local SliderBtn = Instance.new("TextButton")
        SliderBtn.Size = UDim2.new(1, -20, 0, 8)
        SliderBtn.Position = UDim2.new(0, 10, 0, 26)
        SliderBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
        SliderBtn.Text = ""
        SliderBtn.Parent = Frame
        Instance.new("UICorner", SliderBtn).CornerRadius = UDim.new(1, 0)

        local Progress = Instance.new("Frame")
        Progress.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
        Progress.BackgroundColor3 = Config.ThemeColor
        Progress.Parent = SliderBtn
        Instance.new("UICorner", Progress).CornerRadius = UDim.new(1, 0)
        table.insert(slidersUIList, Progress)

        local snapping = false
        local function UpdateSlider(input)
            local ratio = math.clamp((input.Position.X - SliderBtn.AbsolutePosition.X) / SliderBtn.AbsoluteSize.X, 0, 1)
            local val = math.floor(min + (max - min) * ratio)
            Progress.Size = UDim2.new(ratio, 0, 1, 0)
            Label.Text = labelText .. ": " .. tostring(val)
            callback(val)
        end
        SliderBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then snapping = true UpdateSlider(i) end end)
        UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then snapping = false end end)
        UserInputService.InputChanged:Connect(function(i) if snapping and i.UserInputType == Enum.UserInputType.MouseMovement then UpdateSlider(i) end end)
    end

    -- ── ОСНОВНАЯ ЛОГИКА (ОПТИМИЗИРОВАНО) ───────────────────────────────────

    -- 1. Optimized Ghost Effect (Сзади + Неосязаемый) 
    task.spawn(function()
        while task.wait(0.12) do
            if Config.GhostEffect and LocalPlayer.Character then
                local char = LocalPlayer.Character
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChildOfClass("Humanoid")
                
                if hrp and hum and hum.MoveDirection.Magnitude > 0 then
                    char.Archivable = true
                    local clone = char:Clone()
                    char.Archivable = false
                   
                    for _, v in ipairs(clone:GetDescendants()) do
                        if v:IsA("LuaSourceContainer") or v:IsA("BillboardGui") or v:IsA("ScreenGui") or v:IsA("Highlight") or v:IsA("ParticleEmitter") then
                            v:Destroy()
                        elseif v:IsA("BasePart") then
                            v.CanCollide = false
                            v.CanTouch = false 
                            v.CanQuery = false 
                                                     v.CanQuery = false 
                            v.Anchored = true
                            v.Massless = true
                            v.Material = Enum.Material.ForceField
                            v.Color = Config.GhostColor
                        elseif v:IsA("Decal") or v:IsA("Texture") then
                            v.Transparency = 1 
                        end
                    end
                    
                    local cldHrp = clone:FindFirstChild("HumanoidRootPart")
                    if cldHrp then
                        -- Смещение на 3 стада за спину 
                        cldHrp.CFrame = hrp.CFrame * CFrame.new(0, 0, 3)
                        clone.Parent = Workspace
                        
                        task.spawn(function()
                            for i = 0, 1, 0.15 do
                                task.wait(0.05)
                                for _, p in ipairs(clone:GetDescendants()) do
                                    if p:IsA("BasePart") then p.Transparency = i end
                                end
                            end
                            clone:Destroy()
                        end)
                    else
                        clone:Destroy()
                    end
                end
            end
        end
    end)

    -- 2. Optimized Tracers (Устранение фризов через пул объектов) 
    table.insert(connections, RunService.RenderStepped:Connect(function()
        local tf = ScreenGui:FindFirstChild("TracerFrame")
        if not Config.Tracers then 
            if tf then tf.Visible = false end 
            return 
        end
        
        if not tf then
            tf = Instance.new("Frame", ScreenGui)
            tf.Name = "TracerFrame"
            tf.Size = UDim2.new(1, 0, 1, 0)
            tf.BackgroundTransparency = 1
        end
        tf.Visible = true

        local vp = Camera.ViewportSize
        local origin = Vector2.new(vp.X / 2, vp.Y)
        
        -- Скрываем неиспользуемые линии из пула
        for _, f in pairs(tracerFrames) do f.Visible = false end

        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer or not player.Character then continue end
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end

            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local line = tracerFrames[player.Name]
                if not line then
                    line = Instance.new("Frame", tf)
                    line.BorderSizePixel = 0
                    line.AnchorPoint = Vector2.new(0, 0.5)
                    tracerFrames[player.Name] = line
                end
                
                local isKiller = false -- Тут ваша функция checkIsKiller
                local delta = Vector2.new(pos.X, pos.Y) - origin
                
                line.Visible = true
                line.BackgroundColor3 = Config.EspSurvivorColor -- Упрощено
                line.Position = UDim2.new(0, origin.X, 0, origin.Y)
                line.Size = UDim2.new(0, delta.Magnitude, 0, 1)
                line.Rotation = math.deg(math.atan2(delta.Y, delta.X))
            end
        end
    end))

    -- 3. Optimized Skill Check (Без тяжелых GetDescendants) 
    task.spawn(function()
        while task.wait(0.1) do
            if not Config.PerfectSkillCheck then continue end
            local pg = LocalPlayer:FindFirstChild("PlayerGui")
            if pg then
                for _, sg in ipairs(pg:GetChildren()) do
                    if sg:IsA("ScreenGui") and sg.Enabled then
                        -- Ищем только в активных GUI
                        local check = sg:FindFirstChild("SkillCheck", true) or sg:FindFirstChild("GreatZone", true)
                        if check and check.Visible then
                            VirtualUser:CaptureController()
                            VirtualUser:SetKeyDown(Enum.KeyCode.Space)
                            task.wait(0.02)
                            VirtualUser:SetKeyUp(Enum.KeyCode.Space)
                        end
                    end
                end
            end
        end
    end)

    -- Стандартные функции (Speed, Noclip, ESP) оставлены без изменений, но оптимизированы циклы
    table.insert(connections, RunService.Stepped:Connect(function()
        if Config.Noclip and LocalPlayer.Character then
            for _, v in ipairs(LocalPlayer.Character:GetChildren()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end))

    -- ── ВКЛАДКИ И КНОПКИ ────────────────────────────────────────────────────
