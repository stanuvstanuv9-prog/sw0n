-- Инициализация Drawing ESP с проверкой на поддержку читом
local function CreateDrawingESP(player)
    if player == LocalPlayer or not hasDrawing then return end

    local box = Drawing.new("Square")
    box.Visible = false
    box.Color = Color3.fromRGB(255, 255, 255)
    box.Thickness = 1
    box.Filled = false

    local tracer = Drawing.new("Line")
    tracer.Visible = false
    tracer.Color = Color3.fromRGB(255, 255, 255)
    tracer.Thickness = 1

    local corners = {
        TopLeftH = Drawing.new("Line"), TopLeftV = Drawing.new("Line"),
        TopRightH = Drawing.new("Line"), TopRightV = Drawing.new("Line"),
        BotLeftH = Drawing.new("Line"), BotLeftV = Drawing.new("Line"),
        BotRightH = Drawing.new("Line"), BotRightV = Drawing.new("Line")
    }
    for _, c in pairs(corners) do c.Visible = false; c.Thickness = 1 end

    drawingVisuals[player] = {Box = box, Tracer = tracer, Corners = corners}

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not drawingVisuals[player] then connection:Disconnect() return end
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if char and root and hum and hum.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            if onScreen then
                local color = Color3.fromRGB(0, 255, 120)
                if player.Team and (player.Team.Name:lower():find("kill") or player.Team.Name:lower():find("slash")) or char:GetAttribute("Role") == "Killer" then
                    color = Color3.fromRGB(255, 30, 30)
                end

                local sizeX = 1000 / pos.Z
                local sizeY = 1300 / pos.Z
                local posX = pos.X - sizeX / 2
                local posY = pos.Y - sizeY / 2
                local screenCenterBottom = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)

                if Config.BoxESP then
                    box.Size = Vector2.new(sizeX, sizeY)
                    box.Position = Vector2.new(posX, posY)
                    box.Color = color
                    box.Visible = true
                else box.Visible = false end

                if Config.CornerESP then
                    local length = sizeX / 4
                    corners.TopLeftH.From = Vector2.new(posX, posY); corners.TopLeftH.To = Vector2.new(posX + length, posY)
                    corners.TopLeftV.From = Vector2.new(posX, posY); corners.TopLeftV.To = Vector2.new(posX, posY + length)
                    corners.TopRightH.From = Vector2.new(posX + sizeX, posY); corners.TopRightH.To = Vector2.new(posX + sizeX - length, posY)
                    corners.TopRightV.From = Vector2.new(posX + sizeX, posY); corners.TopRightV.To = Vector2.new(posX + sizeX, posY + length)
                    corners.BotLeftH.From = Vector2.new(posX, posY + sizeY); corners.BotLeftH.To = Vector2.new(posX + length, posY + sizeY)
                    corners.BotLeftV.From = Vector2.new(posX, posY + sizeY); corners.BotLeftV.To = Vector2.new(posX, posY + sizeY - length)
                    corners.BotRightH.From = Vector2.new(posX + sizeX, posY + sizeY); corners.BotRightH.To = Vector2.new(posX + sizeX - length, posY + sizeY)
                    corners.BotRightV.From = Vector2.new(posX + sizeX, posY + sizeY); corners.BotRightV.To = Vector2.new(posX + sizeX, posY + sizeY - length)
                    for _, c in pairs(corners) do c.Color = color; c.Visible = true end
                else for _, c in pairs(corners) do c.Visible = false end end

                if Config.Tracers then
                    tracer.From = screenCenterBottom
                    tracer.To = Vector2.new(pos.X, pos.Y + (sizeY / 2))
                    tracer.Color = color
                    tracer.Visible = true
                else tracer.Visible = false end
            else
                box.Visible = false; tracer.Visible = false
                for _, c in pairs(corners) do c.Visible = false end
            end
        else
            box.Visible = false; tracer.Visible = false
            for _, c in pairs(corners) do c.Visible = false end
        end
    end)
end

Players.PlayerRemoving:Connect(function(player)
    if drawingVisuals[player] then
        pcall(function()
            drawingVisuals[player].Box:Destroy()
            drawingVisuals[player].Tracer:Destroy()
            for _, c in pairs(drawingVisuals[player].Corners) do c:Destroy() end
        end)
        drawingVisuals[player] = nil
    end
end)

local function applyPlayerESP(player)
    if player == LocalPlayer then return end
    local function onChar(character)
        if espFolders[player] then pcall(function() espFolders[player]:Destroy() end) end
        if not Config.ESP then return end
        local root = character:WaitForChild("HumanoidRootPart", 5)
        if not root then return end
        
        local folder = Instance.new("Folder", character)
        folder.Name = "Luna_ESP"
        espFolders[player] = folder

        local bb = Instance.new("BillboardGui", folder)
        bb.Size = UDim2.new(0, 160, 0, 40)
        bb.AlwaysOnTop = true
        bb.Adornee = root

        local txt = Instance.new("TextLabel", bb)
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Font = Enum.Font.GothamBold
        txt.TextSize = 12
        txt.TextStrokeTransparency = 0
        
        local isKiller = player.Team and (player.Team.Name:lower():find("kill") or player.Team.Name:lower():find("slash")) or character:GetAttribute("Role") == "Killer"
        txt.Text = isKiller and ("[ МАНЬЯК ]\n" .. player.DisplayName) or ("[ Выживший ]\n" .. player.DisplayName)
        txt.TextColor3 = isKiller and Color3.fromRGB(255, 30, 30) or Color3.fromRGB(0, 255, 120)
    end
    player.CharacterAdded:Connect(onChar)
    if player.Character then onChar(player.Character) end
end

local function toggleNameESP(state)
    if state then for _, p in ipairs(Players:GetPlayers()) do applyPlayerESP(p) end
    else for _, f in pairs(espFolders) do pcall(function() f:Destroy() end) end; table.clear(espFolders) end
end

