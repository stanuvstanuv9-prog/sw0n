    table.insert(connections, RunService.RenderStepped:Connect(function(dt)
        if not LocalPlayer.Character then return end
        local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hrp and hum and hum.MoveDirection.Magnitude > 0 and Config.CFrameSpeed then
            local spd = Config.SpeedValue
            if Config.AutoSprint and isSprinting then spd = spd * 1.8 end
            hrp.CFrame = hrp.CFrame + (hum.MoveDirection * (spd * dt * 10))
        end
    end))

    table.insert(connections, RunService.RenderStepped:Connect(function()
        if not LocalPlayer.Character then return end
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        if Config.NoFall and hum:GetState() == Enum.HumanoidStateType.Freefall then
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
        if not Config.CFrameSpeed and Config.AutoSprint then
            if isSprinting then
                hum.WalkSpeed = Config.SprintWalkSpeed
            else
                if hum.WalkSpeed == Config.SprintWalkSpeed then
                    hum.WalkSpeed = Config.NormalWalkSpeed
                end
            end
        end
    end))

    table.insert(connections, RunService.Stepped:Connect(function()
        if Config.Noclip and LocalPlayer.Character then
            for _, part in ipairs(LocalPlayer.Character:GetChildren()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end))

    table.insert(connections, RunService.RenderStepped:Connect(function()
        if Camera and Camera.FieldOfView ~= Config.FOVValue then
            Camera.FieldOfView = Config.FOVValue
        end
    end))

    table.insert(connections, RunService.RenderStepped:Connect(function()
        if Config.Fullbright then
            Lighting.Ambient = Color3.fromRGB(255, 255, 255)
            Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
            Lighting.Brightness = 3
            Lighting.ClockTime = 14
            Lighting.FogEnd = 999999
            Lighting.GlobalShadows = false
        end
    end))

    local antiAfkConnection
    local function toggleAntiAFK(state)
        if state then
            if not antiAfkConnection then
                antiAfkConnection = LocalPlayer.Idled:Connect(function()
                    pcall(function()
                        VirtualUser:CaptureController()
                        VirtualUser:ClickButton2(Vector2.new(0, 0))
                    end)
                end)
            end
        else
            if antiAfkConnection then
                antiAfkConnection:Disconnect()
                antiAfkConnection = nil
            end
        end
    end

    local function toggleFullbright(state)
        if not state then
            Lighting.Ambient = originalLighting.Ambient
            Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
            Lighting.Brightness = originalLighting.Brightness
            Lighting.ClockTime = originalLighting.ClockTime
            Lighting.FogEnd = originalLighting.FogEnd
            Lighting.GlobalShadows = originalLighting.GlobalShadows
        end
    end

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
            isSprinting = true
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
            isSprinting = false
            if LocalPlayer.Character then
                local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if hum and not Config.CFrameSpeed and hum.WalkSpeed == Config.SprintWalkSpeed then
                    hum.WalkSpeed = Config.NormalWalkSpeed
                end
            end
        end
    end)

    local function applyWallMod(state)
        if state then
            Lighting.Ambient = Config.WallColorValue
        else
            Lighting.Ambient = originalLighting.Ambient
        end
    end

    local function scansForWeapons(container)
        if not container then return false end
        for _, item in ipairs(container:GetChildren()) do
            if item:IsA("Tool") then
                local iName = item.Name:lower()
                if not iName:find("flashlight") and not iName:find("medkit")
                   and not iName:find("cola") and not iName:find("camera") then
                    return true
                end
            end
        end
        return false
    end

    local function checkIsKiller(player, character)
        if not player then return false end
        if player.Team then
            local tName = player.Team.Name:lower()
            if tName:find("kill") or tName:find("slash") or tName:find("beast")
               or tName:find("murder") or tName:find("hunter") then
                return true
            end
        end
        if player:GetAttribute("Role") == "Killer" or player:GetAttribute("IsKiller") == true then
            return true
        end
        if character and (character:GetAttribute("Role") == "Killer"
            or character:GetAttribute("IsKiller") == true) then
            return true
        end
        if character and scansForWeapons(character) then return true end
        if player:FindFirstChild("Backpack") and scansForWeapons(player.Backpack) then return true end
        return false
    end

    local function getOrCreateBillboard(character, color, labelText)
        local folder = character:FindFirstChild("Luna_Visuals_Container")
        if not folder then
            folder = Instance.new("Folder")
            folder.Name = "Luna_Visuals_Container"
            folder.Parent = character
        end

        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local bb = folder:FindFirstChild("LunaBB")
        if Config.ESP then
            if not bb then
                bb = Instance.new("BillboardGui")
                bb.Name = "LunaBB"
                bb.AlwaysOnTop = true
                bb.Size = UDim2.new(0, 120, 0, 40)
                bb.StudsOffset = Vector3.new(0, 3, 0)
                bb.Adornee = hrp
                bb.Parent = folder

                local tl = Instance.new("TextLabel")
                tl.Name = "NameLabel"
                tl.Size = UDim2.new(1, 0, 1, 0)
                tl.BackgroundTransparency = 1
                tl.Font = Enum.Font.GothamBold
                tl.TextSize = 13
                tl.TextStrokeTransparency = 0.5
                tl.Parent = bb
            end
            local tl = bb:FindFirstChild("NameLabel")
            if tl then
                tl.Text = labelText
                tl.TextColor3 = color
            end
        else
            if bb then bb:Destroy() end
        end

        local sel = folder:FindFirstChild("LunaBox")
        if Config.Box then
            if not sel then
                sel = Instance.new("SelectionBox")
                sel.Name = "LunaBox"
                sel.LineThickness = 0.05
                sel.SurfaceTransparency = 0.7
                sel.Adornee = character
                sel.Parent = folder
            end
            sel.Color3 = color
            sel.SurfaceColor3 = color
        else
            if sel then sel:Destroy() end
        end

        local tracerGui = ScreenGui:FindFirstChild("TracerFrame")
        if Config.Tracers then
            if not tracerGui then
                tracerGui = Instance.new("Frame")
                tracerGui.Name = "TracerFrame"
                tracerGui.Size = UDim2.new(1, 0, 1, 0)
                tracerGui.BackgroundTransparency = 1
                tracerGui.Parent = ScreenGui
            end
        end
    end

    task.spawn(function()
        while task.wait(0.1) do
            for _, player in ipairs(Players:GetPlayers()) do
                if player == LocalPlayer then continue end
                local character = player.Character
                if not character then continue end
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if not hrp then continue end

                local isKiller = checkIsKiller(player, character)
                local espColor = isKiller and Color3.fromRGB(255, 30, 30) or Color3.fromRGB(0, 255, 120)
                local espText = isKiller
                    and ("[ МАНЬЯК ] " .. player.Name)
                    or ("[ Выживший ] " .. player.Name)

                getOrCreateBillboard(character, espColor, espText)
            end

            for _, child in ipairs(Workspace:GetChildren()) do
                local folder = child:FindFirstChild("Luna_Visuals_Container")
                if folder then
                    local stillInGame = false
                    for _, pl in ipairs(Players:GetPlayers()) do
                        if pl.Character == child then stillInGame = true break end
                    end
                    if not stillInGame then folder:Destroy() end
                end
            end
        end
    end)

    table.insert(connections, RunService.RenderStepped:Connect(function()
        local tf = ScreenGui:FindFirstChild("TracerFrame")
        if not tf then return end
        for _, c in ipairs(tf:GetChildren()) do c:Destroy() end
        if not Config.Tracers then return end

        local vp = Camera.ViewportSize
        local origin = Vector2.new(vp.X / 2, vp.Y)

        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            local character = player.Character
            if not character then continue end
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end

            local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if not onScreen then continue end

            local isKiller = checkIsKiller(player, character)
            local lineColor = isKiller and Color3.fromRGB(255, 60, 60) or Color3.fromRGB(0, 255, 120)

            local target = Vector2.new(screenPos.X, screenPos.Y)
            local delta = target - origin
            local length = delta.Magnitude
            local angle = math.atan2(delta.Y, delta.X)

            local line = Instance.new("Frame")
            line.BackgroundColor3 = lineColor
            line.BorderSizePixel = 0
            line.AnchorPoint = Vector2.new(0, 0.5)
            line.Position = UDim2.new(0, origin.X, 0, origin.Y)
            line.Size = UDim2.new(0, length, 0, 1)
            line.Rotation = math.deg(angle)
            line.Parent = tf
        end
    end))

    task.spawn(function()
        while task.wait(0.5) do
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local existingSnow = hrp:FindFirstChild("LunaSnowEmitter")
