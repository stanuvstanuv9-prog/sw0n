				local pos = math.clamp((input.Position.X - BarBg.AbsolutePosition.X) / BarBg.AbsoluteSize.X, 0, 1)
				local value = math.floor(Min + ((Max - Min) * pos))
				Util:Tween(Fill, {Size = UDim2.new(pos, 0, 1, 0)}, 0.05)
				Label.Text = Title .. ": " .. tostring(value)
				task.spawn(Callback, value)
			end

			BarBg.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					sliding = true
					update(input)
				end
			end)
			UIS.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					sliding = false
				end
			end)
			UIS.InputChanged:Connect(function(input)
				if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					update(input)
				end
			end)
		end

		-- ВЫПАДАЮЩИЙ СПИСОК (Dropdown) с адаптивной прокруткой списка под мобилки
		function PageComponents:CreateDropdown(config)
			config = config or {}
			local Title = config.Title or config.Text or "Выпадающий список"
			local Options = config.List or config.Array or {}
			local Callback = config.Callback or function() end

			local DropFrame = Instance.new("Frame", PageContent)
			local DFCorner = Instance.new("UICorner")
			local DropBtn = Instance.new("TextButton", DropFrame)
			local Scroll = Instance.new("ScrollingFrame", DropFrame)
			local SLayout = Instance.new("UIListLayout", Scroll)

			DropFrame.Size = UDim2.new(1, -5, 0, 32)
			DropFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
			DropFrame.ClipsDescendants = true
			DFCorner.CornerRadius = UDim.new(0, 4)
			DFCorner.Parent = DropFrame

			DropBtn.Size = UDim2.new(1, 0, 0, 32)
			DropBtn.BackgroundTransparency = 1
			DropBtn.Font = Enum.Font.SourceSansSemibold
			DropBtn.Text = "  " .. Title .. "  ▼"
			DropBtn.TextColor3 = Color3.fromRGB(240, 240, 240)
			DropBtn.TextSize = 14
			DropBtn.TextXAlignment = Enum.TextXAlignment.Left

			Scroll.Size = UDim2.new(1, 0, 1, -32)
			Scroll.Position = UDim2.new(0, 0, 0, 32)
			Scroll.BackgroundTransparency = 1
			Scroll.ScrollBarThickness = 2
			Scroll.ScrollBarImageColor3 = Color3.fromRGB(0, 0, 0)
			SLayout.SortOrder = Enum.SortOrder.LayoutOrder

			local isOpen = false
			DropBtn.MouseButton1Click:Connect(function()
				isOpen = not isOpen
				local targetSize = isOpen and UDim2.new(1, -5, 0, math.min(32 + (#Options * 26), 136)) or UDim2.new(1, -5, 0, 32)
				Util:Tween(DropFrame, {Size = targetSize}, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
				DropBtn.Text = isOpen and "  " .. Title .. "  ▲" or "  " .. Title .. "  ▼"
			end)

			for _, opt in ipairs(Options) do
				local optBtn = Instance.new("TextButton", Scroll)
				optBtn.Size = UDim2.new(1, 0, 0, 25)
				optBtn.BackgroundColor3 = Color3.fromRGB(42, 42, 42)
				optBtn.BackgroundTransparency = 0.2
				optBtn.Font = Enum.Font.SourceSans
				optBtn.Text = tostring(opt)
				optBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
				optBtn.TextSize = 14
				Instance.new("UICorner", optBtn).CornerRadius = UDim.new(0, 3)

				optBtn.MouseButton1Click:Connect(function()
					DropBtn.Text = "  " .. Title .. " : " .. tostring(opt) .. "  ▼"
					isOpen = false
					Util:Tween(DropFrame, {Size = UDim2.new(1, -5, 0, 32)}, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
					task.spawn(Callback, opt)
				end)
			end
		end
-- =============================================================================
-- ЧАСТЬ 4: СИСТЕМА БИНДОВ (KEYBIND), ЗАКРЫТИЕ ИНТЕРФЕЙСА И ПРИМЕР ЗАПУСКА
-- =============================================================================

		-- КЛАВИША БИНДА (Keybind) — кастомный выбор кнопки активации функций (для ПК)
		function PageComponents:CreateKeybind(config)
			config = config or {}
			local Title = config.Title or config.Text or "Назначить клавишу"
			local Default = config.Default or Enum.KeyCode.E
			local Callback = config.Callback or function() end

			local BindFrame = Instance.new("Frame", PageContent)
			local BFCorner = Instance.new("UICorner")
			local Label = Instance.new("TextLabel", BindFrame)
			local BindBtn = Instance.new("TextButton", BindFrame)
			local BBCorner = Instance.new("UICorner")

			BindFrame.Name = Title .. "_BindFrame"
			BindFrame.Size = UDim2.new(1, -5, 0, 32)
			BindFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
			BFCorner.CornerRadius = UDim.new(0, 4)
			BFCorner.Parent = BindFrame

			Label.Size = UDim2.new(1, -100, 1, 0)
			Label.Position = UDim2.new(0, 10, 0, 0)
			Label.BackgroundTransparency = 1
			Label.Font = Enum.Font.SourceSansSemibold
			Label.Text = Title
			Label.TextColor3 = Color3.fromRGB(230, 230, 230)
			Label.TextSize = 14
			Label.TextXAlignment = Enum.TextXAlignment.Left

			BindBtn.Size = UDim2.new(0, 80, 0, 22)
			BindBtn.Position = UDim2.new(1, -90, 0.5, -11)
			BindBtn.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
			BindBtn.Font = Enum.Font.SourceSansBold
			BindBtn.Text = Default.Name
			BindBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
			BindBtn.TextSize = 12
			BBCorner.CornerRadius = UDim.new(0, 4)
			BBCorner.Parent = BindBtn

			local currentKey = Default
			local listening = false

			-- Логика ожидания нажатия новой клавиши
			BindBtn.MouseButton1Click:Connect(function()
				listening = true
				BindBtn.Text = "..."
				BindBtn.TextColor3 = Color3.fromRGB(255, 165, 0)
			end)

			UIS.InputBegan:Connect(function(input, processed)
				if processed then return end
				
				if listening then
					if input.UserInputType == Enum.UserInputType.Keyboard then
						local key = input.KeyCode
						-- Проверяем, не находится ли клавиша в черном списке
						if not table.find(BlacklistedKeys, key) then
							currentKey = key
							BindBtn.Text = key.Name
							listening = false
							BindBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
						end
					end
				else
					-- Если не слушаем новый бинд, то просто выполняем функцию при нажатии
					if input.KeyCode == currentKey then
						task.spawn(Callback)
					end
				end
			end)
		end

		return PageComponents
	end

	return Elements
end

