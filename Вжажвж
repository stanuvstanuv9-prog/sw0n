-- Создаем вкладку БЕЗ иконки (чистый текст, чтобы Solara не крашилась)
local MainTab = Window:CreateTab("Rage Функции") 

-- Настройки софта
local SilentAimEnabled = false
local EspEnabled = false
local AutofireEnabled = false
local TeamCheck = true
local TargetPart = "Head" 
local AutofireDelay = 0.05 

-- Сервисы игры
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local Mouse = LocalPlayer:GetMouse()

-- [ СОЗДАНИЕ ТУМБЛЕРОВ ]
MainTab:CreateToggle({
   Name = "Silent Aim (Аим без доводки)",
   CurrentValue = false,
   Callback = function(Value)
      SilentAimEnabled = Value
   end,
})

MainTab:CreateToggle({
   Name = "Autofire (Автовыстрел)",
   CurrentValue = false,
   Callback = function(Value)
      AutofireEnabled = Value
   end,
})

MainTab:CreateToggle({
   Name = "Wallhack / ESP (Подсветка)",
   CurrentValue = false,
