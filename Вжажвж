local SilentAimEnabled = false
local EspEnabled = false
local AutofireEnabled = false
local TeamCheck = true
local TargetPart = "Head"

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local Mouse = LocalPlayer:GetMouse()

local function getClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(TargetPart) then
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                if TeamCheck and player.Team == LocalPlayer.Team then continue end
                
                local pos, onScreen = Camera:WorldToViewportPoint(player.Character[TargetPart].Position)
                if onScreen then
                    local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    if distance < shortestDistance then
                        closestPlayer = player
                        shortestDistance = distance
                    end
                end
            end
        end
    end
    return closestPlayer
end

-- FIX: Изменение параметров в __namecall требует распаковки измененной таблицы или перезаписи args
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if SilentAimEnabled and (method == "FindPartOnRayWithIgnoreList" or method == "FindPartOnRayWithWhitelist" or method == "FindPartOnRay" or method == "Raycast") then
        local target = getClosestPlayer()
        if target and target.Character and target.Character:FindFirstChild(TargetPart) then
            if method == "Raycast" then
                local origin = args[1]
                local direction = (target.Character[TargetPart].Position - origin).unit * 5000
                args[2] = direction
                return oldNamecall(self, unpack(args))
            else
                local origin = args[1].Origin
                local direction = (target.Character[TargetPart].Position - origin).unit * 5000
                args[1] = Ray.new(origin, direction)
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)

-- FIX: Хук __index падал, если self не является инстансом (например, при чтении таблиц/векторов), добавлен typeof() check
local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, index)
    if SilentAimEnabled and typeof(self) == "Instance" and self == Mouse and (index == "Hit" or index == "Target") then
        local target = getClosestPlayer()
        if target and target.Character and target.Character:FindFirstChild(TargetPart) then
            if index == "Hit" then return target.Character[TargetPart].CFrame end
            if index == "Target" then return target.Character[TargetPart] end
        end
    end
    return oldIndex(self, index)
end)

-- FIX: Оптимизирован деструктор ESP, удаляем только из персонажей во избежание фризов от полного обхода workspace
local function clearESP()
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character then
            local highlight = player.Character:FindFirstChild("XenoESP")
            if highlight then highlight:Destroy() end
        end
    end
end

-- FIX: Adornee и родитель теперь проверяются на валидность, предотвращен спам копий
local function updateESP()
    if not EspEnabled then return end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") then
            if TeamCheck and player.Team == LocalPlayer.Team then 
                local old = player.Character:FindFirstChild("XenoESP")
                if old then old:Destroy() end
                continue 
            end
            
            if not player.Character:FindFirstChild("XenoESP") then
                local highlight = Instance.new("Highlight")
                highlight.Name = "XenoESP"
                highlight.FillColor = Color3.fromRGB(170, 0, 255)
                highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                highlight.FillTransparency = 0.4
                highlight.OutlineTransparency = 0
                highlight.Adornee = player.Character
                highlight.Parent = player.Character
            end
        end
    end
end

-- FIX: Принудительная очистка при выключении флага внутри цикла
task.spawn(function()
    while task.wait(0.5) do
        if EspEnabled then 
            updateESP() 
        else
            clearESP()
        end
    end
end)

