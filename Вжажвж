MainTab:CreateToggle({
   Name = "Team Check (Игнор тимы)",
   CurrentValue = true,
   Callback = function(Value)
      TeamCheck = Value
   end,
})

MainTab:CreateSlider({
   Name = "Задержка автофаера",
   Min = 0.01,
   Max = 0.3,
   CurrentValue = 0.05,
   Callback = function(Value)
      AutofireDelay = Value
   end,
})

-- [ ФУНКЦИЯ ПОИСКА ЦЕЛИ ]
local function getClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(TargetPart) then
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                if TeamCheck and player.Team == LocalPlayer.Team then continue end
                
                local pos, onScreen = Camera:WorldToViewportPoint(player.Character[TargetPart].Position)
                if onScreen then
                    local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    if distance < shortestDistance then
                        closestPlayer = player
                        shortestDistance = distance
                    end
                end
            end
        end
    end
    return closestPlayer
end

-- [ ХУК МЕТАТАБЛИЦЫ ДЛЯ SILENT AIM ]
-- Обернуто в pcall, чтобы если у Solara отвалятся метатаблицы, остальной скрипт работал
pcall(function()
    local gmt = getrawmetatable(game)
    setreadonly(gmt, false)
    local oldIndex = gmt.__index

    gmt.__index = newcclosure(function(self, idx)
        if self == Mouse and (idx == "Hit" or idx == "Target") and SilentAimEnabled then
            local target = getClosestPlayer()
            if target and target.Character and target.Character:FindFirstChild(TargetPart) then
                if idx == "Hit" then
                    return target.Character[TargetPart].CFrame
                elseif idx == "Target" then
                    return target.Character[TargetPart]
                end
            end
        end
        return oldIndex(self, idx)
    end)
    setreadonly(gmt, true)
end)

-- [ ПОТОК ДЛЯ ESP ]
task.spawn(function()
    while task.wait(0.5) do
        if EspEnabled then
            -- Чистим старые чамсы
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Highlight") and obj.Name == "HvH_Highlight" then
                    obj:Destroy()
                end
            end
            -- Рисуем новые
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
                    if TeamCheck and player.Team == LocalPlayer.Team then continue end
                    
                    local highlight = Instance.new("Highlight")
                    highlight.Name = "HvH_Highlight"
                    highlight.FillColor = Color3.fromRGB(255, 0, 85)
                    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    highlight.FillTransparency = 0.3
                    highlight.Adornee = player.Character
                    highlight.Parent = player.Character
                end
            end
        end
    end
end)

-- [ ПОТОК ДЛЯ AUTOFIRE ]
task.spawn(function()
    while task.wait() do
        if AutofireEnabled then
            local target = getClosestPlayer()
            if target and mouse1click then
                mouse1click()
                task.wait(AutofireDelay)
            end
        end
    end
end)

